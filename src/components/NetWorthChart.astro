---
import type { NetWorthPoint } from '../ops/reads';
import { fmtUSD, fmtTickMonthDay, isDisplayZero } from '../lib/format';
import { CHART_W, CHART_H, CHART_PAD_T, CHART_INNER_H } from '../lib/chart';
import { CAPTURE_BASELINE_YMD } from '../lib/baseline';
import Chart, { type ChartHoverPoint, type ChartPath, type ChartTick } from './Chart.astro';

interface Props {
  series: NetWorthPoint[];
}

const { series } = Astro.props;

// Anchor everything at the capture-baseline. Pre-baseline NW totals were
// missing accounts (Schwab) so the line would jump when imports landed —
// the chart and headline delta both start from this point forward.
const points_ = series.filter((p) => !p.synthetic && p.date >= CAPTURE_BASELINE_YMD);

const xAt = (i: number) => (i / Math.max(points_.length - 1, 1)) * CHART_W;

// === Line view ========================================================
const lineY = (() => {
  const totals = points_.map((p) => p.total_cents);
  const lo = totals.length ? Math.min(...totals) : 0;
  const hi = totals.length ? Math.max(...totals) : 0;
  const span = Math.max(hi - lo, 1);
  const yMin = lo - span * 0.08;
  const yMax = hi + span * 0.08;
  const yRange = yMax - yMin || 1;
  return (cents: number) => CHART_PAD_T + (1 - (cents - yMin) / yRange) * CHART_INNER_H;
})();

const linePath = points_
  .map((p, i) => `${i === 0 ? 'M' : 'L'} ${xAt(i).toFixed(2)} ${lineY(p.total_cents).toFixed(2)}`)
  .join(' ');

const lineArea =
  points_.length > 1
    ? `${linePath} L ${xAt(points_.length - 1).toFixed(2)} ${(CHART_PAD_T + CHART_INNER_H).toFixed(2)} L ${xAt(0).toFixed(2)} ${(CHART_PAD_T + CHART_INNER_H).toFixed(2)} Z`
    : '';

const linePaths: ChartPath[] = points_.length > 0 ? [{ d: linePath, variant: 'solid' }] : [];

const tickCount = Math.min(6, points_.length);
const ticks: ChartTick[] = Array.from({ length: tickCount }, (_, k) => {
  const i = tickCount === 1 ? 0 : Math.round((k * (points_.length - 1)) / (tickCount - 1));
  return { x: xAt(i), label: fmtTickMonthDay(points_[i].date) };
});

const first = points_[0] ?? null;
const last = points_[points_.length - 1] ?? null;
const change = first && last ? last.total_cents - first.total_cents : 0;
const changePct = first && first.total_cents !== 0 ? change / first.total_cents : 0;

const fmtReadoutDate = (ymd: string) => {
  const [y, m, d] = ymd.split('-').map(Number);
  return new Date(Date.UTC(y, m - 1, d)).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC',
  });
};

const lineHoverPoints: ChartHoverPoint[] = points_.map((p, i) => ({
  x: xAt(i),
  y: lineY(p.total_cents),
  readout: `${fmtReadoutDate(p.date)} · ${fmtUSD.format(p.total_cents / 100)}`,
}));

// === Breakdown view (absolute split-y + side legend) ==================
type LayerCfg = {
  key: string;
  label: string;
  cls: string;        // legend swatch class
  bandCls: string;    // SVG band class
  neg: boolean;
  get: (p: NetWorthPoint) => number;
};

const ASSET_LAYERS: LayerCfg[] = [
  { key: 'invest', label: 'Investments', cls: 'sw-invest', bandCls: 'band-a-1', neg: false, get: (p) => p.invest_cents },
  { key: 'other',  label: 'Other',       cls: 'sw-other',  bandCls: 'band-a-2', neg: false, get: (p) => p.other_cents },
  { key: 'priv',   label: 'Private',     cls: 'sw-priv',   bandCls: 'band-a-3', neg: false, get: (p) => p.private_cents },
  { key: 'cash',   label: 'Cash',        cls: 'sw-cash',   bandCls: 'band-a-4', neg: false, get: (p) => p.cash_cents },
];

const LIAB_LAYERS: LayerCfg[] = [
  { key: 'amort', label: 'Amortized', cls: 'sw-amort', bandCls: 'band-l-1', neg: true, get: (p) => p.amortized_cents },
  { key: 'rev',   label: 'Revolving', cls: 'sw-rev',   bandCls: 'band-l-2', neg: true, get: (p) => p.revolving_cents },
];

const ALL_LAYERS = [...ASSET_LAYERS, ...LIAB_LAYERS];

const assetTotals = points_.map((p) => ASSET_LAYERS.reduce((s, l) => s + l.get(p), 0));
const liabTotals = points_.map((p) => LIAB_LAYERS.reduce((s, l) => s + l.get(p), 0));
const grossTotals = assetTotals.map((a, i) => Math.max(a + liabTotals[i], 1));

// Split-y axis: at proportional scale, liabilities (~10-15% of NW) would
// be a thin red strip. Give the bottom region a fixed share of the chart
// so its bands stay legible at their own scale.
const BOT_FRAC = 0.22;
const maxAssets = assetTotals.length ? Math.max(...assetTotals) : 0;
const maxLiabs = liabTotals.length ? Math.max(...liabTotals) : 0;
const assetScale = maxAssets * 1.08;
const liabScale = maxLiabs * 1.20;
const effBotFrac = maxLiabs > 0 ? BOT_FRAC : 0;
const assetHeight = (1 - effBotFrac) * CHART_INNER_H;
const liabHeight = effBotFrac * CHART_INNER_H;
const zeroY = CHART_PAD_T + assetHeight;

const yA = (v: number) => zeroY - (v / Math.max(assetScale, 1)) * assetHeight;
const yL = (v: number) => zeroY + (v / Math.max(liabScale, 1)) * liabHeight;

function areaPath(values: number[], yFn: (v: number) => number, lower: number[]): string {
  if (values.length < 2) return '';
  const top = values.map((v, i) => `${i === 0 ? 'M' : 'L'} ${xAt(i).toFixed(2)} ${yFn(v).toFixed(2)}`).join(' ');
  const bot = lower.map((v, i) => ({ i, v })).reverse().map(({ i, v }) => `L ${xAt(i).toFixed(2)} ${yFn(v).toFixed(2)}`).join(' ');
  return `${top} ${bot} Z`;
}

const assetBands: { d: string; cls: string }[] = [];
{
  let cum = points_.map(() => 0);
  for (const layer of ASSET_LAYERS) {
    const next = cum.map((c, i) => c + layer.get(points_[i]));
    assetBands.push({ d: areaPath(next, yA, cum), cls: layer.bandCls });
    cum = next;
  }
}
const liabBands: { d: string; cls: string }[] = [];
{
  let cum = points_.map(() => 0);
  for (const layer of LIAB_LAYERS) {
    const next = cum.map((c, i) => c + layer.get(points_[i]));
    liabBands.push({ d: areaPath(next, yL, cum), cls: layer.bandCls });
    cum = next;
  }
}
// NW line — top of asset stack
const nwLinePath = points_
  .map((p, i) => `${i === 0 ? 'M' : 'L'} ${xAt(i).toFixed(2)} ${yA(assetTotals[i]).toFixed(2)}`)
  .join(' ');

const fmtPct1 = (n: number) => `${(n * 100).toFixed(1)}%`;

// Per-point legend data: cents + pct-of-gross for each band, plus the NW
// total. JS swaps these into the legend on hover.
type LegendCell = { cents: number; pct: number };
type LegendPoint = {
  x: number;
  y: number;
  date: string;
  nwCents: number;
  nwPct: number;
  rows: LegendCell[]; // same order as ALL_LAYERS
};
const legendPoints: LegendPoint[] = points_.map((p, i) => {
  const g = grossTotals[i];
  return {
    x: xAt(i),
    y: yA(assetTotals[i]),
    date: fmtReadoutDate(p.date),
    nwCents: p.total_cents,
    nwPct: p.total_cents / g,
    rows: ALL_LAYERS.map((l) => ({ cents: l.get(p), pct: l.get(p) / g })),
  };
});
const lastLegend = legendPoints[legendPoints.length - 1] ?? null;

const deltaZero = isDisplayZero(change);
const pos = change >= 0;

const hasData = points_.length > 0;
const breakdownHasShape = points_.length > 1;

// === Multiples view (small multiples grid) ============================
const SM_W = 200;
const SM_H = 36;

type MultCard = {
  key: string;
  label: string;
  cls: string;
  neg: boolean;
  curCents: number;
  pctOfGross: number;
  changeCents: number;
  changePct: number;
  sparkPath: string;
  areaPath: string;
  hasSpark: boolean;
};

const multCards: MultCard[] = ALL_LAYERS.map((l) => {
  const values = points_.map(l.get);
  const cur = values[values.length - 1] ?? 0;
  const startVal = values[0] ?? 0;
  const changeCents = cur - startVal;
  const changePct = startVal !== 0 ? changeCents / startVal : 0;
  const gLast = grossTotals[grossTotals.length - 1] ?? 0;
  const pctOfGross = gLast > 0 ? cur / gLast : 0;

  let sparkPath = '';
  let aPath = '';
  let hasSpark = false;
  if (values.length >= 2) {
    const lo = Math.min(...values);
    const hi = Math.max(...values);
    const span = Math.max(hi - lo, 1);
    const sxAt = (i: number) => (i / (values.length - 1)) * SM_W;
    const syAt = (v: number) => SM_H - 3 - ((v - lo) / span) * (SM_H - 6);
    sparkPath = values.map((v, i) => `${i === 0 ? 'M' : 'L'} ${sxAt(i).toFixed(1)} ${syAt(v).toFixed(1)}`).join(' ');
    aPath = `${sparkPath} L ${sxAt(values.length - 1).toFixed(1)} ${SM_H} L 0 ${SM_H} Z`;
    hasSpark = true;
  }
  return {
    key: l.key, label: l.label, cls: l.cls, neg: l.neg,
    curCents: cur, pctOfGross, changeCents, changePct,
    sparkPath, areaPath: aPath, hasSpark,
  };
});
---
<div class="nw-chart" data-mode="line">
  <div class="nw-toolbar">
    <div class="nw-toggle" role="tablist">
      <button type="button" data-mode="line" class="active" title="Trend" aria-label="Trend">
        <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><polyline points="1,12 5,7 9,9 15,3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter" /></svg>
      </button>
      <button type="button" data-mode="breakdown" title="Breakdown" aria-label="Breakdown">
        <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
          <path d="M0 16 L0 11 L4 7 L8 9 L12 5 L16 7 L16 16 Z" fill="currentColor" fill-opacity="0.25"/>
          <path d="M0 16 L0 13 L4 10 L8 12 L12 8 L16 10 L16 16 Z" fill="currentColor" fill-opacity="0.45"/>
          <path d="M0 16 L0 15 L4 13 L8 14 L12 11 L16 13 L16 16 Z" fill="currentColor" fill-opacity="0.75"/>
        </svg>
      </button>
      <button type="button" data-mode="multiples" title="Components" aria-label="Components">
        <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
          <rect x="1" y="2" width="4" height="4" fill="currentColor" />
          <rect x="6" y="2" width="4" height="4" fill="currentColor" />
          <rect x="11" y="2" width="4" height="4" fill="currentColor" />
          <rect x="1" y="10" width="4" height="4" fill="currentColor" />
          <rect x="6" y="10" width="4" height="4" fill="currentColor" />
          <rect x="11" y="10" width="4" height="4" fill="currentColor" />
        </svg>
      </button>
    </div>
  </div>

  <div class="nw-view view-line">
    <Chart
      label={`net worth · last ${points_.length} ${points_.length === 1 ? 'day' : 'days'}`}
      empty="NO SNAPSHOTS YET — DAILY CRON FILLS THIS IN."
      delta={points_.length > 1 ? { cents: change, pct: changePct, pctDecimals: 2 } : null}
      area={lineArea}
      paths={linePaths}
      ticks={ticks}
      points={lineHoverPoints}
    />
  </div>

  <div class="nw-view view-breakdown">
    <header class="break-head">
      <span class="break-label">net worth · breakdown</span>
      {points_.length > 1 && (
        deltaZero ? (
          <div class="break-delta zero"><span class="num">—</span></div>
        ) : (
          <div class={`break-delta ${pos ? 'pos' : 'neg'}`}>
            <span class="num">{pos ? '+' : '−'}{fmtUSD.format(Math.abs(change) / 100)}</span>
            <span class="num pct">({pos ? '+' : '−'}{(Math.abs(changePct) * 100).toFixed(2)}%)</span>
          </div>
        )
      )}
      <div class="break-readout" aria-live="polite"></div>
    </header>

    {!hasData ? (
      <p class="break-empty">NO SNAPSHOTS YET — DAILY CRON FILLS THIS IN.</p>
    ) : !breakdownHasShape ? (
      <p class="break-empty">BREAKDOWN BEGINS WITH A SECOND SNAPSHOT — CHECK BACK TOMORROW.</p>
    ) : (
      <div class="break-body">
        <div class="break-wrap" data-points={JSON.stringify(legendPoints)} data-vb-w={CHART_W}>
          <svg viewBox={`0 0 ${CHART_W} ${CHART_H}`} preserveAspectRatio="none" class="break-svg" role="img" aria-label="net worth breakdown">
            {assetBands.map((b) => (
              <path d={b.d} class={`break-band ${b.cls}`} />
            ))}
            {liabBands.map((b) => (
              <path d={b.d} class={`break-band ${b.cls}`} />
            ))}
            <line x1="0" x2={CHART_W} y1={zeroY.toFixed(2)} y2={zeroY.toFixed(2)} class="break-zero" vector-effect="non-scaling-stroke" />
            <path d={nwLinePath} class="break-line" vector-effect="non-scaling-stroke" />
            <g class="break-hover" style="display:none">
              <line class="break-cross" y1={CHART_PAD_T} y2={CHART_PAD_T + CHART_INNER_H} vector-effect="non-scaling-stroke" />
              <circle class="break-dot" r="3" />
            </g>
          </svg>
          <div class="break-axis">
            {ticks.map((t) => (
              <span class="break-tick" style={`left: ${(t.x / CHART_W) * 100}%`}>{t.label}</span>
            ))}
          </div>
        </div>
        <aside class="break-legend">
          <table>
            {ALL_LAYERS.map((l, idx) => (
              <tr data-idx={idx}>
                <td class="sw"><span class={`bd-sw ${l.cls}`} /></td>
                <td class="cat">{l.label}</td>
                <td class={`amt ${l.neg ? 'neg' : ''}`} data-amt>
                  {l.neg ? '−' : ''}{lastLegend ? fmtUSD.format(lastLegend.rows[idx].cents / 100) : '—'}
                </td>
                <td class="pct" data-pct>{lastLegend ? fmtPct1(lastLegend.rows[idx].pct) : '—'}</td>
              </tr>
            ))}
            <tr class="tot">
              <td class="sw"><span class="bd-sw sw-nw" /></td>
              <td class="cat">Net worth</td>
              <td class="amt" data-nw>{lastLegend ? fmtUSD.format(lastLegend.nwCents / 100) : '—'}</td>
              <td class="pct" data-nw-pct>{lastLegend ? fmtPct1(lastLegend.nwPct) : '—'}</td>
            </tr>
          </table>
        </aside>
      </div>
    )}
  </div>

  <div class="nw-view view-multiples">
    <header class="break-head">
      <span class="break-label">net worth · components</span>
      {points_.length > 1 && (
        deltaZero ? (
          <div class="break-delta zero"><span class="num">—</span></div>
        ) : (
          <div class={`break-delta ${pos ? 'pos' : 'neg'}`}>
            <span class="num">{pos ? '+' : '−'}{fmtUSD.format(Math.abs(change) / 100)}</span>
            <span class="num pct">({pos ? '+' : '−'}{(Math.abs(changePct) * 100).toFixed(2)}%)</span>
          </div>
        )
      )}
    </header>

    {!hasData ? (
      <p class="break-empty">NO SNAPSHOTS YET — DAILY CRON FILLS THIS IN.</p>
    ) : (
      <div class="mult-grid">
        {multCards.map((c) => {
          // "good" direction differs for liabilities (paying debt down = good)
          const goodMove = c.neg ? c.changeCents < 0 : c.changeCents > 0;
          const deltaCls = c.changeCents === 0 ? '' : (goodMove ? 'pos' : 'neg');
          const sign = c.changeCents > 0 ? '+' : c.changeCents < 0 ? '−' : '';
          return (
            <div class="sm-card">
              <div class="sm-head">
                <span class={`bd-sw ${c.cls}`} />
                <span class="sm-cat">{c.label}</span>
                <span class="sm-pct">{fmtPct1(c.pctOfGross)}</span>
              </div>
              <div class={`sm-amt ${c.neg ? 'neg' : ''}`}>
                {c.neg ? '−' : ''}{fmtUSD.format(c.curCents / 100)}
              </div>
              {c.hasSpark && (
                <svg class="sm-svg" viewBox={`0 0 ${SM_W} ${SM_H}`} preserveAspectRatio="none" aria-hidden="true">
                  <path d={c.areaPath} class={`sm-area ${c.neg ? 'neg-fill' : ''}`} />
                  <path d={c.sparkPath} class={`sm-spark ${c.neg ? 'neg-stroke' : ''}`} />
                </svg>
              )}
              {points_.length > 1 ? (
                <div class={`sm-delta ${deltaCls}`}>
                  <span class="num">{sign}{fmtUSD.format(Math.abs(c.changeCents) / 100)}</span>
                  <span class="num pct">({sign}{(Math.abs(c.changePct) * 100).toFixed(1)}%)</span>
                </div>
              ) : (
                <div class="sm-delta zero"><span class="num">—</span></div>
              )}
            </div>
          );
        })}
      </div>
    )}
  </div>
</div>

<script>
  type LegendCell = { cents: number; pct: number };
  type LegendPt = { x: number; y: number; date: string; nwCents: number; nwPct: number; rows: LegendCell[] };

  const fmtUSD0 = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
  const fmtPct1 = (n: number) => `${(n * 100).toFixed(1)}%`;

  for (const root of document.querySelectorAll<HTMLElement>('.nw-chart')) {
    // toggle
    for (const btn of root.querySelectorAll<HTMLButtonElement>('.nw-toggle button')) {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.mode!;
        root.dataset.mode = mode;
        for (const b of root.querySelectorAll<HTMLButtonElement>('.nw-toggle button')) {
          b.classList.toggle('active', b.dataset.mode === mode);
        }
      });
    }

    // breakdown hover — updates side legend + crosshair
    const wrap = root.querySelector<HTMLElement>('.break-wrap');
    if (!wrap) continue;
    const pts = JSON.parse(wrap.dataset.points!) as LegendPt[];
    if (pts.length === 0) continue;
    const vbW = Number(wrap.dataset.vbW);
    const svg = wrap.querySelector<SVGSVGElement>('svg')!;
    const hoverG = wrap.querySelector<SVGGElement>('.break-hover')!;
    const cross = hoverG.querySelector<SVGLineElement>('.break-cross')!;
    const dot = hoverG.querySelector<SVGCircleElement>('.break-dot')!;
    const head = root.querySelector<HTMLElement>('.break-head')!;
    const readout = head.querySelector<HTMLElement>('.break-readout')!;
    const legend = root.querySelector<HTMLElement>('.break-legend')!;
    const rowEls = Array.from(legend.querySelectorAll<HTMLTableRowElement>('tr[data-idx]'));
    const nwAmtEl = legend.querySelector<HTMLElement>('[data-nw]')!;
    const nwPctEl = legend.querySelector<HTMLElement>('[data-nw-pct]')!;

    const renderLegend = (pt: LegendPt) => {
      for (let i = 0; i < rowEls.length; i++) {
        const row = rowEls[i];
        const cell = pt.rows[i];
        const amtEl = row.querySelector<HTMLElement>('[data-amt]')!;
        const pctEl = row.querySelector<HTMLElement>('[data-pct]')!;
        const neg = amtEl.classList.contains('neg');
        amtEl.textContent = (neg ? '−' : '') + fmtUSD0.format(cell.cents / 100);
        pctEl.textContent = fmtPct1(cell.pct);
      }
      nwAmtEl.textContent = fmtUSD0.format(pt.nwCents / 100);
      nwPctEl.textContent = fmtPct1(pt.nwPct);
    };

    const onMove = (e: PointerEvent) => {
      const rect = svg.getBoundingClientRect();
      if (rect.width === 0) return;
      const xView = ((e.clientX - rect.left) / rect.width) * vbW;
      let best = pts[0];
      let bestDelta = Math.abs(xView - best.x);
      for (const p of pts) {
        const delta = Math.abs(xView - p.x);
        if (delta < bestDelta) { best = p; bestDelta = delta; }
      }
      cross.setAttribute('x1', String(best.x));
      cross.setAttribute('x2', String(best.x));
      dot.setAttribute('cx', String(best.x));
      dot.setAttribute('cy', String(best.y));
      hoverG.style.display = '';
      readout.textContent = `${best.date} · ${fmtUSD0.format(best.nwCents / 100)}`;
      head.classList.add('hovering');
      renderLegend(best);
    };
    const onLeave = () => {
      hoverG.style.display = 'none';
      head.classList.remove('hovering');
      renderLegend(pts[pts.length - 1]);
    };
    wrap.addEventListener('pointermove', onMove);
    wrap.addEventListener('pointerleave', onLeave);
  }
</script>

<style>
  .nw-chart {
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--rule);
    padding-bottom: var(--space-6);
    display: grid;
    gap: var(--space-3);
  }

  /* toolbar */
  .nw-toolbar { display: flex; justify-content: flex-end; }
  .nw-toggle { display: flex; border: 1px solid var(--rule-strong); }
  .nw-toggle button {
    background: var(--bg);
    border: 0;
    border-right: 1px solid var(--rule-strong);
    padding: 0.3rem 0.5rem;
    font: inherit;
    color: var(--fg-muted);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }
  .nw-toggle button:last-child { border-right: 0; }
  .nw-toggle button.active { background: var(--fg); color: var(--bg); }
  .nw-toggle button:hover:not(.active) { color: var(--fg); }
  .nw-toggle button svg { display: block; }
  @media (max-width: 40rem) {
    .nw-toggle button { padding: 0.5rem 0.75rem; }
    .nw-toggle button svg { width: 16px; height: 16px; }
  }

  /* view switching */
  .nw-view { display: none; }
  .nw-chart[data-mode="line"] .view-line { display: block; }
  .nw-chart[data-mode="breakdown"] .view-breakdown { display: block; }
  .nw-chart[data-mode="multiples"] .view-multiples { display: block; }

  /* shared head (breakdown + multiples) */
  .break-head {
    position: relative;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .break-label {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    transition: opacity 80ms linear;
  }
  .break-delta {
    display: inline-flex;
    gap: var(--space-2);
    align-items: baseline;
    font-size: var(--size-sm);
    font-variant-numeric: tabular-nums;
    transition: opacity 80ms linear;
  }
  .break-delta .pct { color: var(--fg-muted); font-size: var(--size-xs); }
  .break-delta.pos { color: var(--pos); }
  .break-delta.neg { color: var(--neg); }
