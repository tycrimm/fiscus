---
import type { NetWorthPoint } from '../ops/reads';
import { fmtUSD, fmtTickMonthDay } from '../lib/format';
import { CHART_W, CHART_PAD_T, CHART_INNER_H } from '../lib/chart';
import { CAPTURE_BASELINE_YMD } from '../lib/baseline';
import Chart, { type ChartHoverPoint, type ChartPath, type ChartTick } from './Chart.astro';

interface Props {
  series: NetWorthPoint[];
}

const { series } = Astro.props;

const xAt = (i: number) => (i / Math.max(series.length - 1, 1)) * CHART_W;
const yAt = (() => {
  const totals = series.map((p) => p.total_cents);
  const lo = totals.length ? Math.min(...totals) : 0;
  const hi = totals.length ? Math.max(...totals) : 0;
  const span = Math.max(hi - lo, 1);
  const yMin = lo - span * 0.08;
  const yMax = hi + span * 0.08;
  const yRange = yMax - yMin || 1;
  return (cents: number) => CHART_PAD_T + (1 - (cents - yMin) / yRange) * CHART_INNER_H;
})();

// Where real data begins (everything before is the synthetic baseline).
const firstRealIdx = series.findIndex((p) => !p.synthetic);
const hasSynthetic = firstRealIdx > 0;
const realStart = hasSynthetic ? firstRealIdx : 0;

const buildPath = (slice: typeof series, offset: number) =>
  slice
    .map((p, i) => `${i === 0 ? 'M' : 'L'} ${xAt(offset + i).toFixed(2)} ${yAt(p.total_cents).toFixed(2)}`)
    .join(' ');

// Synthetic line stops AT the first real point so segments visually connect.
const syntheticSlice = hasSynthetic ? series.slice(0, firstRealIdx + 1) : [];
const realSlice = series.slice(realStart);
const syntheticPath = hasSynthetic ? buildPath(syntheticSlice, 0) : '';
const realPath = buildPath(realSlice, realStart);

// Area only under the real series — synthetic stays as a hairline.
const area =
  realSlice.length > 1
    ? `${realPath} L ${xAt(series.length - 1).toFixed(2)} ${(CHART_PAD_T + CHART_INNER_H).toFixed(2)} L ${xAt(realStart).toFixed(2)} ${(CHART_PAD_T + CHART_INNER_H).toFixed(2)} Z`
    : '';

const paths: ChartPath[] = [];
if (hasSynthetic) paths.push({ d: syntheticPath, variant: 'synthetic' });
paths.push({ d: realPath, variant: 'solid' });

// Up to 6 evenly spaced date ticks.
const tickCount = Math.min(6, series.length);
const ticks: ChartTick[] = Array.from({ length: tickCount }, (_, k) => {
  const i = tickCount === 1 ? 0 : Math.round((k * (series.length - 1)) / (tickCount - 1));
  return { x: xAt(i), label: fmtTickMonthDay(series[i].date) };
});

// Headline delta is anchored at the capture-baseline, not the first real
// point. Pre-baseline NW totals were missing accounts (Schwab) so a "since
// 2024" delta would mostly reflect when imports landed, not actual change.
// The chart line itself still spans full history — we just don't claim a
// number that crosses the baseline.
const baselineFirst = series.find((p) => !p.synthetic && p.date >= CAPTURE_BASELINE_YMD) ?? null;
const realLast = series[series.length - 1];
const change = realLast && baselineFirst ? realLast.total_cents - baselineFirst.total_cents : 0;
const changePct = baselineFirst && baselineFirst.total_cents !== 0 ? change / baselineFirst.total_cents : 0;
const baselineDays = baselineFirst
  ? series.filter((p) => !p.synthetic && p.date >= CAPTURE_BASELINE_YMD).length
  : 0;

const fmtReadoutDate = (ymd: string) => {
  const [y, m, d] = ymd.split('-').map(Number);
  return new Date(Date.UTC(y, m - 1, d)).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC',
  });
};

const points: ChartHoverPoint[] = series.map((p, i) => ({
  x: xAt(i),
  y: yAt(p.total_cents),
  readout: `${fmtReadoutDate(p.date)} · ${fmtUSD.format(p.total_cents / 100)}${p.synthetic ? ' · baseline' : ''}`,
}));
---
<div class="nw-chart">
  <Chart
    label={`net worth · last ${series.length} days`}
    empty="NO SNAPSHOTS YET — DAILY CRON FILLS THIS IN."
    delta={baselineDays > 1 ? { cents: change, pct: changePct, pctDecimals: 2 } : null}
    area={area}
    paths={paths}
    ticks={ticks}
    points={points}
  />
</div>

<style>
  .nw-chart {
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--rule);
    padding-bottom: var(--space-6);
  }
</style>
