---
import type { NetWorthPoint } from '../ops/reads';
import { fmtUSD } from '../lib/format';

interface Props {
  series: NetWorthPoint[];
}

const { series } = Astro.props;

const W = 1000;
const H = 220;
const PAD_T = 8;
const PAD_B = 22;
const innerH = H - PAD_T - PAD_B;

const totals = series.map((p) => p.total_cents);
const lo = totals.length ? Math.min(...totals) : 0;
const hi = totals.length ? Math.max(...totals) : 0;
const span = Math.max(hi - lo, 1);
const yMin = lo - span * 0.08;
const yMax = hi + span * 0.08;
const yRange = yMax - yMin || 1;

const xAt = (i: number) => (i / Math.max(series.length - 1, 1)) * W;
const yAt = (cents: number) => PAD_T + (1 - (cents - yMin) / yRange) * innerH;

// Index where real data begins (everything before is the synthetic baseline)
const firstRealIdx = series.findIndex((p) => !p.synthetic);
const hasSynthetic = firstRealIdx > 0;
const realStart = hasSynthetic ? firstRealIdx : 0;

const buildPath = (slice: typeof series, offset: number) =>
  slice
    .map((p, i) => `${i === 0 ? 'M' : 'L'} ${xAt(offset + i).toFixed(2)} ${yAt(p.total_cents).toFixed(2)}`)
    .join(' ');

// Synthetic line stops AT the first real point so segments visually connect.
const syntheticSlice = hasSynthetic ? series.slice(0, firstRealIdx + 1) : [];
const realSlice = series.slice(realStart);

const syntheticPath = hasSynthetic ? buildPath(syntheticSlice, 0) : '';
const realPath = buildPath(realSlice, realStart);

// Area only under the real series — synthetic stays as a hairline.
const areaPath =
  realSlice.length > 1
    ? `${realPath} L ${xAt(series.length - 1).toFixed(2)} ${(PAD_T + innerH).toFixed(2)} L ${xAt(realStart).toFixed(2)} ${(PAD_T + innerH).toFixed(2)} Z`
    : '';

const fmtTickDate = (ymd: string) => {
  const [y, m, d] = ymd.split('-').map(Number);
  return new Date(Date.UTC(y, m - 1, d)).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  });
};

// Pick up to 6 evenly spaced date ticks
const tickCount = Math.min(6, series.length);
const ticks = Array.from({ length: tickCount }, (_, k) => {
  const i = tickCount === 1 ? 0 : Math.round((k * (series.length - 1)) / (tickCount - 1));
  return { i, label: fmtTickDate(series[i].date) };
});

// Real-data delta only — synthetic baseline shouldn't drive the headline number.
const realFirst = series[realStart];
const realLast = series[series.length - 1];
const change = realLast && realFirst ? realLast.total_cents - realFirst.total_cents : 0;
const changePct = realFirst && realFirst.total_cents !== 0 ? change / realFirst.total_cents : 0;
const changePos = change >= 0;
const realDays = series.length - realStart;
---
<section class="nw-chart">
  <header class="nw-head">
    <div>
      <span class="nw-label">net worth · last {series.length} days</span>
      {hasSynthetic && (
        <span class="nw-tag">{realDays} {realDays === 1 ? 'real day' : 'real days'} · rest is baseline</span>
      )}
    </div>
    {realDays > 1 && (
      <div class={`nw-delta ${changePos ? 'pos' : 'neg'}`}>
        <span class="num">{changePos ? '+' : '−'}{fmtUSD.format(Math.abs(change) / 100)}</span>
        <span class="num pct">({changePos ? '+' : '−'}{(Math.abs(changePct) * 100).toFixed(2)}%)</span>
      </div>
    )}
  </header>

  {series.length === 0 ? (
    <p class="nw-empty">NO SNAPSHOTS YET — DAILY CRON FILLS THIS IN.</p>
  ) : (
    <>
      <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none" class="nw-svg" role="img" aria-label="Net worth time series">
        {areaPath && <path d={areaPath} class="area" />}
        {syntheticPath && <path d={syntheticPath} class="line synthetic" vector-effect="non-scaling-stroke" />}
        <path d={realPath} class="line" vector-effect="non-scaling-stroke" />
      </svg>
      <div class="nw-axis">
        {ticks.map((t) => (
          <span class="tick" style={`left: ${(xAt(t.i) / W) * 100}%`}>{t.label}</span>
        ))}
      </div>
    </>
  )}
</section>

<style>
  .nw-chart {
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--rule);
    padding-bottom: var(--space-6);
  }
  .nw-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }
  .nw-label {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
  }
  .nw-delta {
    display: inline-flex;
    gap: var(--space-2);
    align-items: baseline;
    font-size: var(--size-sm);
    font-variant-numeric: tabular-nums;
  }
  .nw-delta .pct { color: var(--fg-muted); font-size: var(--size-xs); }
  .nw-delta.pos { color: var(--pos); }
  .nw-delta.neg { color: var(--neg); }

  .nw-svg {
    width: 100%;
    height: 220px;
    display: block;
  }
  .area { fill: var(--fg); fill-opacity: 0.06; stroke: none; }
  .line { fill: none; stroke: var(--fg); stroke-width: 1.25; }
  .line.synthetic {
    stroke: var(--rule-strong);
    stroke-dasharray: 3 3;
    stroke-width: 1;
  }
  .nw-tag {
    margin-left: var(--space-2);
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .nw-axis {
    position: relative;
    height: 1em;
    margin-top: var(--space-1);
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .tick {
    position: absolute;
    top: 0;
    transform: translateX(-50%);
    white-space: nowrap;
  }
  .tick:first-child { transform: translateX(0); }
  .tick:last-child { transform: translateX(-100%); }

  .nw-empty {
    color: var(--fg-muted);
    padding: var(--space-12) 0;
    text-align: center;
    font-size: var(--size-sm);
  }
</style>
