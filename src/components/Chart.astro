---
import { fmtUSD, isDisplayZero } from '../lib/format';
import { CHART_W, CHART_H, CHART_PAD_T, CHART_INNER_H } from '../lib/chart';

export type ChartPath = { d: string; variant?: 'solid' | 'synthetic' | 'ghost'; label?: string };
export type ChartMark = { x: number; y: number };
export type ChartTick = { x: number; label: string };
export type ChartYTick = { y: number; label: string };
export type ChartHoverPoint = { x: number; y: number; readout: string };
export type ChartDelta = { cents: number; pct: number; pctDecimals?: number };

interface Props {
  label: string;
  empty?: string;
  delta?: ChartDelta | null;
  area?: string;
  bandArea?: string;
  paths?: ChartPath[];
  marks?: ChartMark[];
  ticks?: ChartTick[];
  yTicks?: ChartYTick[];
  points?: ChartHoverPoint[];
  dotR?: number;
  todayX?: number;
}

const {
  label,
  empty = 'NO DATA YET.',
  delta = null,
  area,
  bandArea,
  paths = [],
  marks = [],
  ticks = [],
  yTicks = [],
  points = [],
  dotR = 3,
  todayX,
} = Astro.props;

const hasData = points.length > 0;
// Treat sub-dollar deltas as zero — whole-dollar formatting would otherwise
// render them as red "−$0" / green "+$0" from rounding noise.
const deltaZero = delta != null && isDisplayZero(delta.cents);
const pos = delta ? delta.cents >= 0 : true;
const pctDec = delta?.pctDecimals ?? 2;
---
<section class="chart">
  <header class="chart-head">
    <span class="chart-label">{label}</span>
    {delta && (
      deltaZero ? (
        <div class="chart-delta zero"><span class="num">—</span></div>
      ) : (
        <div class={`chart-delta ${pos ? 'pos' : 'neg'}`}>
          <span class="num">{pos ? '+' : '−'}{fmtUSD.format(Math.abs(delta.cents) / 100)}</span>
          <span class="num pct">({pos ? '+' : '−'}{(Math.abs(delta.pct) * 100).toFixed(pctDec)}%)</span>
        </div>
      )
    )}
    <div class="chart-readout" aria-live="polite"></div>
  </header>

  {!hasData ? (
    <p class="chart-empty">{empty}</p>
  ) : (
    <div
      class={`chart-wrap${yTicks.length ? ' has-y-axis' : ''}`}
      data-points={JSON.stringify(points)}
      data-vb-w={CHART_W}
    >
      {yTicks.length > 0 && (
        <div class="chart-y-axis">
          {yTicks.map((t) => (
            <span class="chart-y-tick" style={`top: ${(t.y / CHART_H) * 100}%`}>{t.label}</span>
          ))}
        </div>
      )}
      <div class="chart-plot">
        <svg viewBox={`0 0 ${CHART_W} ${CHART_H}`} preserveAspectRatio="none" class="chart-svg" role="img" aria-label={label}>
          {yTicks.map((t) => (
            <line
              class="chart-gridline"
              x1="0"
              x2={CHART_W}
              y1={t.y.toFixed(2)}
              y2={t.y.toFixed(2)}
              vector-effect="non-scaling-stroke"
            />
          ))}
          {area && <path d={area} class="chart-area" />}
          {bandArea && <path d={bandArea} class="chart-band-area" />}
          {paths.map((p) => (
            <path
              d={p.d}
              class={`chart-line ${p.variant ?? 'solid'}`}
              vector-effect="non-scaling-stroke"
            >
              {p.label && <title>{p.label}</title>}
            </path>
          ))}
          {todayX != null && (
            <line
              class="chart-today"
              x1={todayX.toFixed(2)}
              x2={todayX.toFixed(2)}
              y1={CHART_PAD_T}
              y2={CHART_PAD_T + CHART_INNER_H}
              vector-effect="non-scaling-stroke"
            />
          )}
          {marks.map((m) => (
            <circle cx={m.x.toFixed(2)} cy={m.y.toFixed(2)} r="2.5" class="chart-mark" />
          ))}
          <g class="chart-hover" style="display:none">
            <line class="chart-cross" y1={CHART_PAD_T} y2={CHART_PAD_T + CHART_INNER_H} vector-effect="non-scaling-stroke" />
            <circle class="chart-dot" r={dotR} />
          </g>
        </svg>
        <div class="chart-axis">
          {ticks.map((t) => (
            <span class="chart-tick" style={`left: ${(t.x / CHART_W) * 100}%`}>{t.label}</span>
          ))}
        </div>
      </div>
    </div>
  )}
</section>

<script>
  type Pt = { x: number; y: number; readout: string };

  for (const wrap of document.querySelectorAll<HTMLElement>('.chart-wrap')) {
    const points = JSON.parse(wrap.dataset.points!) as Pt[];
    if (points.length === 0) continue;
    const vbW = Number(wrap.dataset.vbW);
    const svg = wrap.querySelector('svg')!;
    const hoverG = wrap.querySelector<SVGGElement>('.chart-hover')!;
    const cross = hoverG.querySelector<SVGLineElement>('.chart-cross')!;
    const dot = hoverG.querySelector<SVGCircleElement>('.chart-dot')!;
    const head = wrap.parentElement!.querySelector<HTMLElement>('.chart-head')!;
    const readout = head.querySelector<HTMLElement>('.chart-readout')!;

    const onMove = (e: PointerEvent) => {
      const rect = svg.getBoundingClientRect();
      if (rect.width === 0) return;
      const xView = ((e.clientX - rect.left) / rect.width) * vbW;
      let best = points[0];
      let bestDelta = Math.abs(xView - best.x);
      for (const p of points) {
        const delta = Math.abs(xView - p.x);
        if (delta < bestDelta) { best = p; bestDelta = delta; }
      }
      cross.setAttribute('x1', String(best.x));
      cross.setAttribute('x2', String(best.x));
      dot.setAttribute('cx', String(best.x));
      dot.setAttribute('cy', String(best.y));
      hoverG.style.display = '';
      readout.textContent = best.readout;
      head.classList.add('hovering');
    };
    const onLeave = () => {
      hoverG.style.display = 'none';
      head.classList.remove('hovering');
    };
    wrap.addEventListener('pointermove', onMove);
    wrap.addEventListener('pointerleave', onLeave);
  }
</script>

<style>
  .chart { display: grid; gap: var(--space-2); }
  .chart-head {
    position: relative;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .chart-label {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    transition: opacity 80ms linear;
  }
  .chart-delta {
    display: inline-flex;
    gap: var(--space-2);
    align-items: baseline;
    font-size: var(--size-sm);
    font-variant-numeric: tabular-nums;
    transition: opacity 80ms linear;
  }
  .chart-delta .pct { color: var(--fg-muted); font-size: var(--size-xs); }
  .chart-delta.pos { color: var(--pos); }
  .chart-delta.neg { color: var(--neg); }
  .chart-delta.zero { color: var(--fg-muted); }
  .chart-head.hovering .chart-label,
  .chart-head.hovering .chart-delta { opacity: 0; }

  .chart-wrap {
    position: relative;
    touch-action: none;
  }
  .chart-wrap.has-y-axis {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3);
  }
  .chart-plot { position: relative; min-width: 0; }
  .chart-y-axis {
    position: relative;
    width: 3.25rem;
    height: 220px;
    font-size: var(--size-xs);
    color: var(--fg-muted);
    font-variant-numeric: tabular-nums;
  }
  .chart-y-tick {
    position: absolute;
    right: 0;
    transform: translateY(-50%);
    white-space: nowrap;
  }
  .chart-svg {
    width: 100%;
    height: 220px;
    display: block;
    overflow: visible;
  }
  .chart-area { fill: var(--fg); fill-opacity: 0.06; stroke: none; }
  .chart-band-area { fill: var(--fg); fill-opacity: 0.03; stroke: none; }
  .chart-gridline {
    stroke: var(--rule);
    stroke-width: 1;
    stroke-dasharray: 2 4;
  }
  .chart-today {
    stroke: var(--fg-muted);
    stroke-opacity: 0.6;
    stroke-width: 1;
    stroke-dasharray: 3 3;
  }
  .chart-line { fill: none; stroke: var(--fg); stroke-width: 1.25; }
  .chart-line.synthetic {
    stroke: var(--rule-strong);
    stroke-dasharray: 3 3;
    stroke-width: 1;
  }
  .chart-line.ghost {
    stroke: var(--fg-muted);
    stroke-opacity: 0.45;
    stroke-dasharray: 2 4;
    stroke-width: 1;
  }
  .chart-mark { fill: var(--bg); stroke: var(--fg); stroke-width: 1; }
  .chart-cross {
    stroke: var(--fg-muted);
    stroke-width: 1;
    stroke-dasharray: 2 3;
    pointer-events: none;
  }
  .chart-dot {
    fill: var(--bg);
    stroke: var(--fg);
    stroke-width: 1.25;
    pointer-events: none;
  }
  .chart-readout {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: baseline;
    justify-content: flex-end;
    font-size: var(--size-sm);
    font-variant-numeric: tabular-nums;
    color: var(--fg);
    white-space: nowrap;
    opacity: 0;
    transition: opacity 80ms linear;
    pointer-events: none;
  }
  .chart-head.hovering .chart-readout { opacity: 1; }

  .chart-axis {
    position: relative;
    height: 1em;
    margin-top: var(--space-1);
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .chart-tick {
    position: absolute;
    top: 0;
    transform: translateX(-50%);
    white-space: nowrap;
  }
  .chart-tick:first-child { transform: translateX(0); }
  .chart-tick:last-child { transform: translateX(-100%); }

  .chart-empty {
    color: var(--fg-muted);
    padding: var(--space-12) 0;
    text-align: center;
    font-size: var(--size-sm);
  }
</style>
