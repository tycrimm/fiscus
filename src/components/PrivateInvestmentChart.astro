---
import type { AssetValuePoint } from '../ops/reads';
import { fmtUSD, fmtTickMonthYearShort } from '../lib/format';
import { CHART_W, CHART_PAD_T, CHART_INNER_H } from '../lib/chart';
import Chart, { type ChartHoverPoint, type ChartMark, type ChartTick } from './Chart.astro';

interface Props {
  series: AssetValuePoint[];
}

const { series } = Astro.props;

const values = series.map((p) => p.value_cents);
const lo = values.length ? Math.min(...values) : 0;
const hi = values.length ? Math.max(...values) : 0;
const span = Math.max(hi - lo, 1);
const yMin = Math.max(0, lo - span * 0.1);
const yMax = hi + span * 0.1;
const yRange = yMax - yMin || 1;

// X-axis is time — use as_of unix seconds so visual spacing matches real gaps
// between rounds/marks (e.g. Seed in 2024 vs Series B in 2025). Always stretch
// to today on the right so a stale mark visibly carries a flat line forward.
const nowSec = Math.floor(Date.now() / 1000);
const tMin = series.length ? series[0].as_of : 0;
const tMax = series.length ? Math.max(series[series.length - 1].as_of, nowSec) : nowSec;
const tRange = Math.max(tMax - tMin, 1);

const xAt = (sec: number) => ((sec - tMin) / tRange) * CHART_W;
const yAt = (cents: number) => CHART_PAD_T + (1 - (cents - yMin) / yRange) * CHART_INNER_H;

// Stepped path: value held constant until the next mark, then jumps.
let stepPath = '';
if (series.length > 0) {
  const parts: string[] = [];
  parts.push(`M ${xAt(series[0].as_of).toFixed(2)} ${yAt(series[0].value_cents).toFixed(2)}`);
  for (let i = 1; i < series.length; i++) {
    const prevY = yAt(series[i - 1].value_cents);
    const x = xAt(series[i].as_of);
    const y = yAt(series[i].value_cents);
    parts.push(`L ${x.toFixed(2)} ${prevY.toFixed(2)}`);
    parts.push(`L ${x.toFixed(2)} ${y.toFixed(2)}`);
  }
  // Extend the last value flat out to today.
  const lastY = yAt(series[series.length - 1].value_cents);
  parts.push(`L ${xAt(tMax).toFixed(2)} ${lastY.toFixed(2)}`);
  stepPath = parts.join(' ');
}

const area =
  series.length > 0
    ? `${stepPath} L ${CHART_W.toFixed(2)} ${(CHART_PAD_T + CHART_INNER_H).toFixed(2)} L ${xAt(series[0].as_of).toFixed(2)} ${(CHART_PAD_T + CHART_INNER_H).toFixed(2)} Z`
    : '';

// Tick at each mark, but drop overlaps so labels don't pile up.
const ticks: ChartTick[] = [];
const MIN_TICK_GAP = 80;
for (const p of series) {
  const x = xAt(p.as_of);
  if (ticks.length === 0 || x - ticks[ticks.length - 1].x >= MIN_TICK_GAP) {
    ticks.push({ x, label: fmtTickMonthYearShort(p.as_of) });
  }
}
// Anchor a "today" tick on the right edge when the last mark is visibly older.
const nowX = xAt(nowSec);
if (ticks.length > 0 && nowX - ticks[ticks.length - 1].x < MIN_TICK_GAP) {
  ticks.pop();
}
ticks.push({ x: nowX, label: 'today' });

const marks: ChartMark[] = series.map((p) => ({ x: xAt(p.as_of), y: yAt(p.value_cents) }));

const first = series[0];
const last = series[series.length - 1];
const change = last && first ? last.value_cents - first.value_cents : 0;
const changePct = first && first.value_cents !== 0 ? change / first.value_cents : 0;

const fmtReadoutDate = (ymd: string) => {
  const [y, m, d] = ymd.split('-').map(Number);
  return new Date(Date.UTC(y, m - 1, d)).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC',
  });
};

const points: ChartHoverPoint[] = series.map((p) => ({
  x: xAt(p.as_of),
  y: yAt(p.value_cents),
  readout: `${p.event.label} ${p.event.kind === 'round' ? 'round' : 'mark'} · ${fmtReadoutDate(p.date)} · ${fmtUSD.format(p.value_cents / 100)}`,
}));
---
<Chart
  label={`value history · ${series.length} marks`}
  empty="NO VALUATIONS YET."
  delta={series.length > 1 ? { cents: change, pct: changePct, pctDecimals: 1 } : null}
  area={area}
  paths={stepPath ? [{ d: stepPath, variant: 'solid' }] : []}
  marks={marks}
  ticks={ticks}
  points={points}
  dotR={3.5}
/>
