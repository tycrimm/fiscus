---
import type { AssetValuePoint } from '../ops/reads';
import { fmtUSD, fmtTickMonthYearShort } from '../lib/format';
import { CHART_W, CHART_PAD_T, CHART_INNER_H } from '../lib/chart';
import Chart, { type ChartHoverPoint, type ChartMark, type ChartTick, type ChartYTick } from './Chart.astro';

interface Props {
  series: AssetValuePoint[];
  bearMult?: number;
  bullMult?: number;
}

const { series, bearMult, bullMult } = Astro.props;

const showBand = bearMult != null && bullMult != null && series.length > 0;

// X-axis is time — use as_of unix seconds so visual spacing matches real gaps
// between rounds/marks. When bands are shown, extend the right side into a
// FUTURE window (90 days forward) — this is where ghost bear/bull lines live.
// History extends to today only; bear/bull don't make sense for past values
// (we know what happened).
const FUTURE_DAYS = 90;
const nowSec = Math.floor(Date.now() / 1000);
const tMin = series.length ? series[0].as_of : 0;
const historicalEnd = series.length ? Math.max(series[series.length - 1].as_of, nowSec) : nowSec;
const tMax = showBand ? nowSec + FUTURE_DAYS * 86400 : historicalEnd;
const tRange = Math.max(tMax - tMin, 1);

const xAt = (sec: number) => ((sec - tMin) / tRange) * CHART_W;

const currentValueCents = series.length ? series[series.length - 1].value_cents : 0;

const values = series.map((p) => p.value_cents);
const lo = values.length ? Math.min(...values) : 0;
const hi = values.length ? Math.max(...values) : 0;
// y-range must include: historical min/max, and the current × bear/bull
// multipliers (ghost line endpoints). Anchor the band to *current* — that's
// where the ghost lines actually sit, and it's usually above historical hi
// for an appreciating position.
const effectiveLo = showBand ? Math.min(lo, currentValueCents * bearMult!) : lo;
const effectiveHi = showBand ? Math.max(hi, currentValueCents * bullMult!) : hi;
const span = Math.max(effectiveHi - effectiveLo, 1);
const yMin = Math.max(0, effectiveLo - span * 0.1);
const yMax = effectiveHi + span * 0.1;
const yRange = yMax - yMin || 1;

const yAt = (cents: number) => CHART_PAD_T + (1 - (cents - yMin) / yRange) * CHART_INNER_H;

// Historical step path: held constant between marks, extends flat to today.
function buildStepPath(): string {
  if (series.length === 0) return '';
  const parts: string[] = [];
  parts.push(`M ${xAt(series[0].as_of).toFixed(2)} ${yAt(series[0].value_cents).toFixed(2)}`);
  for (let i = 1; i < series.length; i++) {
    const prevY = yAt(series[i - 1].value_cents);
    const x = xAt(series[i].as_of);
    const y = yAt(series[i].value_cents);
    parts.push(`L ${x.toFixed(2)} ${prevY.toFixed(2)}`);
    parts.push(`L ${x.toFixed(2)} ${y.toFixed(2)}`);
  }
  const lastY = yAt(currentValueCents);
  const endSec = showBand ? nowSec : historicalEnd;
  parts.push(`L ${xAt(endSec).toFixed(2)} ${lastY.toFixed(2)}`);
  return parts.join(' ');
}

// Future ghost line fanning out from TODAY's current value to current × mult
// at the horizon — visualizes uncertainty growing over time.
function buildFutureLine(mult: number): string {
  if (!showBand) return '';
  const xStart = xAt(nowSec).toFixed(2);
  const xEnd = xAt(tMax).toFixed(2);
  const yStart = yAt(currentValueCents).toFixed(2);
  const yEnd = yAt(currentValueCents * mult).toFixed(2);
  return `M ${xStart} ${yStart} L ${xEnd} ${yEnd}`;
}

const stepPath = buildStepPath();
const bearPath = buildFutureLine(bearMult ?? 1);
const bullPath = buildFutureLine(bullMult ?? 1);

// Uncertainty wedge: triangle from (today, current) widening to
// (future, bull) and (future, bear). Fills the space between ghost lines.
const bandArea = showBand
  ? `M ${xAt(nowSec).toFixed(2)} ${yAt(currentValueCents).toFixed(2)} ` +
    `L ${xAt(tMax).toFixed(2)} ${yAt(currentValueCents * bullMult!).toFixed(2)} ` +
    `L ${xAt(tMax).toFixed(2)} ${yAt(currentValueCents * bearMult!).toFixed(2)} Z`
  : '';

// Area fills under the historical step only (stops at today when band on).
const areaEndX = showBand ? xAt(nowSec) : CHART_W;
const area =
  series.length > 0
    ? `${stepPath} L ${areaEndX.toFixed(2)} ${(CHART_PAD_T + CHART_INNER_H).toFixed(2)} L ${xAt(series[0].as_of).toFixed(2)} ${(CHART_PAD_T + CHART_INNER_H).toFixed(2)} Z`
    : '';

// Tick at each mark, but drop overlaps so labels don't pile up.
const ticks: ChartTick[] = [];
const MIN_TICK_GAP = 80;
for (const p of series) {
  const x = xAt(p.as_of);
  if (ticks.length === 0 || x - ticks[ticks.length - 1].x >= MIN_TICK_GAP) {
    ticks.push({ x, label: fmtTickMonthYearShort(p.as_of) });
  }
}
const nowX = xAt(nowSec);
if (ticks.length > 0 && nowX - ticks[ticks.length - 1].x < MIN_TICK_GAP) {
  ticks.pop();
}
ticks.push({ x: nowX, label: 'today' });
// Future horizon tick on the right edge when bands push the chart past today.
if (showBand) {
  ticks.push({ x: xAt(tMax), label: 'future' });
}

// Y-axis: 3 "nice" dollar labels spanning the visible range.
function niceStep(range: number, count: number): number {
  const rawStep = range / (count - 1);
  if (rawStep <= 0) return 1;
  const magnitude = Math.pow(10, Math.floor(Math.log10(rawStep)));
  const normalized = rawStep / magnitude;
  const mult = normalized < 1.5 ? 1 : normalized < 3 ? 2 : normalized < 7 ? 5 : 10;
  return mult * magnitude;
}
function fmtMoneyTick(cents: number): string {
  const d = cents / 100;
  if (d >= 1_000_000) return `$${(d / 1_000_000).toFixed(d % 1_000_000 === 0 ? 0 : 1)}M`;
  if (d >= 1_000) return `$${Math.round(d / 1_000)}K`;
  return `$${Math.round(d)}`;
}
const yTicks: ChartYTick[] = [];
if (series.length > 0) {
  const step = niceStep(yMax - yMin, 3);
  const first = Math.ceil(yMin / step) * step;
  for (let v = first; v <= yMax; v += step) {
    yTicks.push({ y: yAt(v), label: fmtMoneyTick(v) });
  }
}

const marks: ChartMark[] = series.map((p) => ({ x: xAt(p.as_of), y: yAt(p.value_cents) }));

const first = series[0];
const last = series[series.length - 1];
const change = last && first ? last.value_cents - first.value_cents : 0;
const changePct = first && first.value_cents !== 0 ? change / first.value_cents : 0;

const fmtReadoutDate = (ymd: string) => {
  const [y, m, d] = ymd.split('-').map(Number);
  return new Date(Date.UTC(y, m - 1, d)).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC',
  });
};

const points: ChartHoverPoint[] = series.map((p) => ({
  x: xAt(p.as_of),
  y: yAt(p.value_cents),
  readout: `${p.event.label} ${p.event.kind === 'round' ? 'round' : 'mark'} · ${fmtReadoutDate(p.date)} · ${fmtUSD.format(p.value_cents / 100)}`,
}));
---
<Chart
  label={`value history · ${series.length} marks`}
  empty="NO VALUATIONS YET."
  delta={series.length > 1 ? { cents: change, pct: changePct, pctDecimals: 1 } : null}
  area={area}
  bandArea={bandArea}
  paths={[
    ...(bullPath ? [{ d: bullPath, variant: 'ghost' as const, label: 'bull' }] : []),
    ...(bearPath ? [{ d: bearPath, variant: 'ghost' as const, label: 'bear' }] : []),
    ...(stepPath ? [{ d: stepPath, variant: 'solid' as const }] : []),
  ]}
  marks={marks}
  ticks={ticks}
  yTicks={yTicks}
  points={points}
  dotR={3.5}
  todayX={showBand ? nowX : undefined}
/>
