---
interface Props {
  name: string;
  sub: string;
  amount: string;
  asOf?: string;
  owner?: 'tyler' | 'julianne' | 'joint';
  negAmount?: boolean;
}
const { name, sub, amount, asOf, owner, negAmount = false } = Astro.props;
---
<div class:list={['ledger-row', { 'with-asof': asOf != null }]}>
  <div class="primary">
    <span class="name">{name}</span>
    <span class="sub">
      {sub}
      {owner && <><span class="dot">·</span><span class:list={['owner', owner]}>{owner}</span></>}
    </span>
  </div>
  <span class:list={['bal', 'num', { neg: negAmount }]}>{amount}</span>
  {asOf != null && <span class="asof">{asOf}</span>}
</div>

<style>
  .ledger-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
    font-size: var(--size-sm);
  }
  .ledger-row.with-asof { grid-template-columns: 1fr auto 5rem; }
  .ledger-row:last-child { border-bottom: none; }
  .primary { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .name { font-size: var(--size-sm); }
  .sub {
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .sub .dot { margin: 0 0.4em; opacity: 0.55; }
  .owner { color: var(--fg); font-weight: 500; }
  .owner.joint { color: var(--fg-muted); font-weight: 400; }
  .bal { font-variant-numeric: tabular-nums; text-align: right; white-space: nowrap; }
  .asof {
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-align: right;
    white-space: nowrap;
  }

  @media (max-width: 36rem) {
    .ledger-row { grid-template-columns: 1fr auto; row-gap: var(--space-1); }
    .asof { grid-column: 1 / -1; text-align: left; }
  }
</style>
