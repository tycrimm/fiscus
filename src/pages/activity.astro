---
import { env } from 'cloudflare:workers';
import { db } from '../db';
import { activityFeed, listAccounts, type ActivityEvent } from '../ops/reads';
import { fmtUSD, fmtUSDsigned, isDisplayZero } from '../lib/format';
import Shell from '../layouts/Shell.astro';

const d = db(env.DB);
const [events, accounts] = await Promise.all([
  activityFeed(d, { days: 90 }),
  listAccounts(d),
]);

const lastSyncedAt = accounts.reduce<number | null>(
  (max, a) => (a.latest_as_of && (!max || a.latest_as_of > max) ? a.latest_as_of : max),
  null,
);

type DayGroup = { date: string; total_cents: number; events: ActivityEvent[] };
const dayMap = new Map<string, DayGroup>();
for (const e of events) {
  let g = dayMap.get(e.date);
  if (!g) { g = { date: e.date, total_cents: 0, events: [] }; dayMap.set(e.date, g); }
  g.events.push(e);
  g.total_cents += e.delta_cents;
}
// Sort each day's events by signed delta desc — biggest gains at top,
// biggest losses at the bottom. Cleaner narrative than |delta| (which can
// put a small loss above a large gain and break the top-down reading) and
// the bottom of each day reads as "what hurt today" at a glance.
for (const g of dayMap.values()) {
  g.events.sort((a, b) => b.delta_cents - a.delta_cents);
}
const days = [...dayMap.values()].sort((a, b) => (a.date < b.date ? 1 : -1));

const DAY_FMT = new Intl.DateTimeFormat('en-US', {
  timeZone: 'UTC',
  weekday: 'short',
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
function fmtDay(ymd: string): string {
  const [y, m, dd] = ymd.split('-').map(Number);
  return DAY_FMT.format(new Date(Date.UTC(y, m - 1, dd))).toUpperCase();
}

// Snapshot is the default — no badge needed (it's 95%+ of rows). Only
// surface a tag when something more notable happened (a new round, a manual
// mark) so it actually catches the eye.
const KIND_BADGE: Partial<Record<ActivityEvent['kind'], string>> = {
  round: 'ROUND',
  mark: 'MARK',
};
---
<Shell title="activity" lastSyncedAt={lastSyncedAt}>
  {days.length === 0 ? (
    <p class="empty">NO ACTIVITY IN THE LAST 90 DAYS.</p>
  ) : (
    <section class="activity">
      <header class="page-head">
        <h1>activity</h1>
        <p class="hint">Per-event changes that moved net worth, last 90 days. Sign reflects net-worth impact (liability deltas inverted). Within each day, gains descend from the top and losses descend from the bottom.</p>
      </header>
      <table class="activity-table">
        <colgroup>
          <col />
          <col class="col-num" />
          <col class="col-num" />
        </colgroup>
        {days.map((day) => (
          <tbody>
            <tr class="day-head">
              <td>
                <span class="day-date">{fmtDay(day.date)}</span>
                <span class="day-count">{day.events.length} {day.events.length === 1 ? 'event' : 'events'}</span>
              </td>
              <td class:list={['num-col', 'day-total', {
                neg: day.total_cents < 0 && !isDisplayZero(day.total_cents),
                pos: day.total_cents > 0 && !isDisplayZero(day.total_cents),
              }]}>
                {isDisplayZero(day.total_cents) ? '—' : fmtUSDsigned(day.total_cents)}
              </td>
              <td class="num-col"></td>
            </tr>
            {day.events.map((e) => (
              <tr class="event" data-href={e.href} tabindex="0">
                <td class="cell-name">
                  <span class="name">
                    {e.primary}
                    {KIND_BADGE[e.kind] && <span class:list={['badge', e.kind]}>{KIND_BADGE[e.kind]}</span>}
                  </span>
                  <span class="sub">{e.secondary}</span>
                </td>
                <td class:list={['num-col', 'delta', {
                  neg: e.delta_cents < 0 && !isDisplayZero(e.delta_cents),
                  pos: e.delta_cents > 0 && !isDisplayZero(e.delta_cents),
                }]}>
                  {isDisplayZero(e.delta_cents) ? '—' : fmtUSDsigned(e.delta_cents)}
                </td>
                <td class:list={['num-col', 'total', { neg: e.is_liability }]}>
                  {e.is_liability ? `−${fmtUSD.format(e.amount_cents / 100)}` : fmtUSD.format(e.amount_cents / 100)}
                </td>
              </tr>
            ))}
          </tbody>
        ))}
      </table>
    </section>
  )}
</Shell>

<script>
  // Whole-row link target. <tr> can't wrap an <a>; using JS keeps the table
  // semantics clean and right-click still works on the underlying browser
  // navigation menu for the URL we redirect to.
  document.querySelectorAll<HTMLTableRowElement>('.activity-table tr.event').forEach((tr) => {
    const href = tr.dataset.href;
    if (!href) return;
    tr.addEventListener('click', () => { window.location.href = href; });
    tr.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') window.location.href = href;
    });
  });
</script>

<style>
  .activity { display: grid; gap: var(--space-4); }

  .page-head { display: grid; gap: var(--space-2); }
  .page-head .hint {
    margin: 0;
    color: var(--fg-muted);
    font-size: var(--size-sm);
    max-width: 48rem;
  }

  /* Single table for the whole feed so the three columns line up across
     every day. Day separators are tbody-scoped header rows, not their own
     boxes — keeps everything aligned to one grid. */
  .activity-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--size-sm);
  }

  /* `width: 1%` collapses the number columns to their content; the name
     column absorbs the rest of the table width. */
  .col-num { width: 1%; }

  .activity-table td {
    padding: var(--space-2) var(--space-3);
    vertical-align: baseline;
    border-bottom: 1px solid var(--rule);
  }
  .activity-table tbody:last-of-type tr:last-child td { border-bottom: none; }

  .num-col {
    text-align: right;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    padding-left: var(--space-6);
  }

  /* Day separator row */
  .day-head td { background: var(--bg-subtle); }
  .day-date {
    font-size: var(--size-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
  }
  .day-count {
    margin-left: var(--space-3);
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .day-total { font-weight: 500; }

  /* Event row */
  tr.event { cursor: pointer; }
  tr.event:hover { background: var(--bg-subtle); }
  tr.event:focus-visible { outline: 2px solid var(--fg); outline-offset: -2px; }

  .cell-name { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .name {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .sub {
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  /* Round / mark badge — only renders for non-snapshot events. */
  .badge {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.1em 0.4em;
    border: 1px solid var(--rule-strong);
    color: var(--fg-muted);
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
  }

  /* Delta gets pos/neg color. Total stays muted by default and turns red
     only on liability rows so debt balances don't read as assets sitting
     next to brokerage totals. */
  .delta.pos { color: var(--pos); }
  .delta.neg { color: var(--neg); }
  .total { color: var(--fg-muted); }
  .total.neg { color: var(--neg); }
  .day-total.pos { color: var(--pos); }
  .day-total.neg { color: var(--neg); }

  /* ─── Mobile ───────────────────────────────────────────────────────────
     Below ~40rem the three-column desktop grid runs out of horizontal
     room. Reflow each row into a 2×2 block:
        [ name             ]  [ delta ]
        [ INSTITUTION · K  ]  [ total ]
     Numbers stay right-aligned and stacked, name + sub stay left,
     everything keeps its semantic <td>. */
  @media (max-width: 40rem) {
    .activity-table,
    .activity-table tbody,
    .activity-table tr { display: block; }
    .activity-table colgroup { display: none; }

    /* Day header: date + count on the left, day total on the right. The
       trailing empty <td> is hidden — it only existed to align with the
       desktop "total" column. */
    tr.day-head {
      display: grid;
      grid-template-columns: 1fr auto;
      column-gap: var(--space-3);
      align-items: baseline;
      background: var(--bg-subtle);
      padding: var(--space-2) var(--space-3);
    }
    tr.day-head > td {
      padding: 0;
      border: none;
      background: transparent;
    }
    tr.day-head > td:last-child { display: none; }
    .day-count { display: block; margin: 2px 0 0; }

    /* Event row: 2-col grid, name spans both rows on the left, delta/total
       stack on the right. */
    tr.event {
      display: grid;
      grid-template-columns: 1fr auto;
      column-gap: var(--space-3);
      row-gap: 2px;
      align-items: baseline;
      padding: var(--space-2) var(--space-3);
      border-bottom: 1px solid var(--rule);
    }
    tr.event > td {
      padding: 0;
      border: none;
    }
    tr.event > .cell-name { grid-column: 1; grid-row: 1 / span 2; }
    tr.event > .delta { grid-column: 2; grid-row: 1; align-self: start; }
    tr.event > .total {
      grid-column: 2;
      grid-row: 2;
      align-self: end;
      font-size: var(--size-xs);
    }

    .num-col { padding-left: 0; }
    .activity-table tbody:last-of-type tr:last-child { border-bottom: none; }

    /* Hint copy gets long on phones — let it relax instead of dominating. */
    .page-head .hint { font-size: var(--size-xs); }
  }
</style>
