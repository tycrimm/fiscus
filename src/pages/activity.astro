---
import { env } from 'cloudflare:workers';
import { db } from '../db';
import { activityFeed, listAccounts, netWorth, type ActivityEvent } from '../ops/reads';
import { fmtUSD, fmtUSDsigned, isDisplayZero } from '../lib/format';
import Shell from '../layouts/Shell.astro';

const d = db(env.DB);
const [events, accounts, nw] = await Promise.all([
  activityFeed(d, { days: 90 }),
  listAccounts(d),
  netWorth(d),
]);

const lastSyncedAt = accounts.reduce<number | null>(
  (max, a) => (a.latest_as_of && (!max || a.latest_as_of > max) ? a.latest_as_of : max),
  null,
);

type DayGroup = {
  date: string;
  asset_delta_cents: number;
  liability_delta_cents: number;
  total_cents: number;
  events: ActivityEvent[];
};
const dayMap = new Map<string, DayGroup>();
for (const e of events) {
  let g = dayMap.get(e.date);
  if (!g) {
    g = { date: e.date, asset_delta_cents: 0, liability_delta_cents: 0, total_cents: 0, events: [] };
    dayMap.set(e.date, g);
  }
  g.events.push(e);
  g.asset_delta_cents += e.asset_delta_cents;
  g.liability_delta_cents += e.liability_delta_cents;
  g.total_cents += e.delta_cents;
}
// Gains descend from the top of each day; losses from the bottom. Bottom of
// each day reads as "what hurt today" at a glance.
for (const g of dayMap.values()) {
  g.events.sort((a, b) => b.delta_cents - a.delta_cents);
}
const days = [...dayMap.values()].sort((a, b) => (a.date < b.date ? 1 : -1));

// Running NW, walking from the top (most recent) down. Top row's nwAfter is
// current NW; each row below it shows NW as it stood immediately after that
// row's transaction posted (i.e. before the rows above it).
const rowNwAfter = new Map<ActivityEvent, number>();
let nwCursor = nw.total_cents;
for (const day of days) {
  for (const e of day.events) {
    rowNwAfter.set(e, nwCursor);
    nwCursor -= e.delta_cents;
  }
}
// Day-end NW = nwAfter of the topmost (most recent) event in the day.
const dayEndNw = new Map<string, number>();
for (const day of days) {
  const topEvent = day.events[0];
  if (topEvent) dayEndNw.set(day.date, rowNwAfter.get(topEvent)!);
}

const DAY_FMT = new Intl.DateTimeFormat('en-US', {
  timeZone: 'UTC',
  weekday: 'short',
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
function fmtDay(ymd: string): string {
  const [y, m, dd] = ymd.split('-').map(Number);
  return DAY_FMT.format(new Date(Date.UTC(y, m - 1, dd))).toUpperCase();
}

const KIND_BADGE: Partial<Record<ActivityEvent['kind'], string>> = {
  round: 'ROUND',
  mark: 'MARK',
};
---
<Shell title="activity" lastSyncedAt={lastSyncedAt}>
  {days.length === 0 ? (
    <p class="empty">NO ACTIVITY IN THE LAST 90 DAYS.</p>
  ) : (
    <section class="activity">
      <header class="page-head">
        <h1>activity</h1>
        <p class="hint">Daily net-worth ledger, last 90 days. One row per institution per day; same-day cancellations net to zero. Out hurt NW; In helped. Balance is the institution's net at day end; NW is the running net-worth total.</p>
      </header>

      <table class="register">
        <colgroup>
          <col />
          <col class="col-num" />
          <col class="col-num" />
          <col class="col-num" />
          <col class="col-num" />
        </colgroup>
        <thead>
          <tr>
            <th scope="col">Account</th>
            <th scope="col" class="num-col">Out</th>
            <th scope="col" class="num-col">In</th>
            <th scope="col" class="num-col">Balance</th>
            <th scope="col" class="num-col nw">Net Worth</th>
          </tr>
        </thead>
        {days.map((day) => {
          const dayNw = dayEndNw.get(day.date) ?? 0;
          const subtitle: string[] = [];
          if (!isDisplayZero(day.asset_delta_cents)) subtitle.push(`ASSETS ${fmtUSDsigned(day.asset_delta_cents)}`);
          if (!isDisplayZero(day.liability_delta_cents)) subtitle.push(`LIABILITIES ${fmtUSDsigned(-day.liability_delta_cents)}`);
          return (
            <tbody>
              <tr class="day-head">
                <td colspan={4}>
                  <span class="day-date">{fmtDay(day.date)}</span>
                  {subtitle.length > 0 && <span class="day-meta">{subtitle.join(' · ')}</span>}
                  <span class:list={['day-net', {
                    neg: day.total_cents < 0 && !isDisplayZero(day.total_cents),
                    pos: day.total_cents > 0 && !isDisplayZero(day.total_cents),
                  }]}>
                    {isDisplayZero(day.total_cents) ? '—' : fmtUSDsigned(day.total_cents)}
                  </span>
                </td>
                <td class="num-col nw day-nw">{fmtUSDsigned(dayNw)}</td>
              </tr>
              {day.events.map((e) => {
                const out = e.delta_cents < 0 ? -e.delta_cents : 0;
                const inn = e.delta_cents > 0 ? e.delta_cents : 0;
                return (
                  <tr class:list={['event', { 'no-link': !e.href }]} data-href={e.href ?? ''} tabindex={e.href ? 0 : -1}>
                    <td class="cell-name">
                      <span class="name">
                        {e.primary}
                        {KIND_BADGE[e.kind] && <span class:list={['badge', e.kind]}>{KIND_BADGE[e.kind]}</span>}
                      </span>
                      <span class="sub">{e.secondary}</span>
                    </td>
                    <td class="num-col out">
                      {out > 0 && !isDisplayZero(out) ? fmtUSD.format(out / 100) : ''}
                    </td>
                    <td class="num-col in">
                      {inn > 0 && !isDisplayZero(inn) ? fmtUSD.format(inn / 100) : ''}
                    </td>
                    <td class:list={['num-col', 'balance', { neg: e.is_liability }]}>
                      {e.is_liability ? `−${fmtUSD.format(e.amount_cents / 100)}` : fmtUSD.format(e.amount_cents / 100)}
                    </td>
                    <td class="num-col nw">{fmtUSDsigned(rowNwAfter.get(e)!)}</td>
                  </tr>
                );
              })}
            </tbody>
          );
        })}
      </table>
    </section>
  )}
</Shell>

<script>
  document.querySelectorAll<HTMLTableRowElement>('.register tr.event').forEach((tr) => {
    const href = tr.dataset.href;
    if (!href) return;
    tr.addEventListener('click', () => { window.location.href = href; });
    tr.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') window.location.href = href;
    });
  });
</script>

<style>
  .activity { display: grid; gap: var(--space-4); }

  .page-head { display: grid; gap: var(--space-2); }
  .page-head .hint {
    margin: 0;
    color: var(--fg-muted);
    font-size: var(--size-sm);
    max-width: 56rem;
  }

  .register {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--size-sm);
    font-variant-numeric: tabular-nums;
  }
  /* Number columns hug their content so the Account column absorbs the rest. */
  .col-num { width: 1%; }

  .register th,
  .register td {
    padding: var(--space-2) var(--space-3);
    vertical-align: baseline;
    border-bottom: 1px solid var(--rule);
  }
  .register th:first-child,
  .register td:first-child { padding-left: 0; }
  .register th:last-child,
  .register td:last-child { padding-right: 0; }
  .register tbody:last-of-type tr:last-child td { border-bottom: none; }

  /* Vertical gridlines between numeric columns reinforce the ledger feel
     without dominating. Each numeric column gets a left rule; the NW column
     gets a stronger rule because it's the running-total anchor. */
  .register .num-col {
    text-align: right;
    white-space: nowrap;
    padding-left: var(--space-6);
    border-left: 1px solid var(--rule);
  }
  .register .nw { border-left: 1px solid var(--rule-strong); }

  /* Column headers stay sticky under the app header. Padding matches body
     cells so labels sit flush over their columns. */
  .register thead th {
    font-weight: 500;
    color: var(--fg-muted);
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-align: left;
    border-bottom: 1px solid var(--rule-strong);
    background: var(--bg);
    position: sticky;
    top: var(--header-offset);
    z-index: 4;
  }
  .register thead th.num-col { text-align: right; }

  /* Day separator. Single inline row: date on the left, day-net Δ + closing
     NW on the right. The NW total lives in its own cell so it lines up
     directly under the Net Worth column. */
  .day-head td {
    background: var(--bg-subtle);
    padding-top: var(--space-3);
    padding-bottom: var(--space-3);
  }
  .register tbody + tbody .day-head td { padding-top: var(--space-6); }
  .day-date {
    font-size: var(--size-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
  }
  .day-meta {
    margin-left: var(--space-3);
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .day-net {
    float: right;
    font-size: var(--size-sm);
    font-weight: 500;
    color: var(--fg);
  }
  .day-net.pos { color: var(--pos); }
  .day-net.neg { color: var(--neg); }
  .day-nw { font-weight: 500; }

  /* Event row */
  tr.event { cursor: pointer; }
  tr.event.no-link { cursor: default; }
  tr.event:not(.no-link):hover { background: var(--bg-subtle); }
  tr.event:focus-visible { outline: 2px solid var(--fg); outline-offset: -2px; }

  .cell-name { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .name {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .sub {
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .badge {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.1em 0.4em;
    border: 1px solid var(--rule-strong);
    color: var(--fg-muted);
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
  }

  /* Column colors. Empty Out/In cells render blank — column position + sign
     color carry the meaning. */
  .out { color: var(--neg); }
  .in  { color: var(--pos); }
  .balance { color: var(--fg-muted); }
  .balance.neg { color: var(--neg); }
  td.nw { color: var(--fg); }

  /* ─── Mobile ─────────────────────────────────────────────────────────
     Collapse the five-column register into a 2×2 block per row. The Out
     and In columns merge — only one ever has content per row. NW drops
     off; the day header still carries date + day-end NW. */
  @media (max-width: 40rem) {
    .register,
    .register tbody,
    .register tr { display: block; }
    .register colgroup,
    .register thead { display: none; }

    .register tbody + tbody { margin-top: var(--space-4); }
    .register tbody:last-of-type tr:last-child { border-bottom: none; }

    .register tr.day-head {
      display: grid;
      grid-template-columns: 1fr auto;
      column-gap: var(--space-4);
      row-gap: var(--space-1);
      align-items: baseline;
      background: var(--bg-subtle);
      padding: var(--space-3) var(--space-4);
    }
    .register tr.day-head > td {
      padding: 0;
      border: none;
      background: transparent;
    }
    .register tr.day-head > td:first-child { grid-column: 1; }
    .register tr.day-head > td.day-nw { grid-column: 2; text-align: right; }
    .day-net { float: none; display: inline-block; margin-left: var(--space-3); }
    .day-meta { display: block; margin: 2px 0 0; }

    .register tr.event {
      display: grid;
      grid-template-columns: 1fr auto;
      column-gap: var(--space-4);
      row-gap: var(--space-1);
      align-items: baseline;
      padding: var(--space-4) var(--space-4);
      border-bottom: 1px solid var(--rule);
    }
    .register tr.event > td {
      padding: 0;
      border: none;
    }
    .register tr.event > .nw { display: none; }
    .register tr.event > .cell-name { grid-column: 1; grid-row: 1 / span 2; }

    .register tr.event > .out,
    .register tr.event > .in {
      grid-column: 2;
      grid-row: 1;
      align-self: start;
      font-weight: 500;
    }
    .register tr.event > .out:empty,
    .register tr.event > .in:empty { display: none; }

    .register tr.event > .balance {
      grid-column: 2;
      grid-row: 2;
      align-self: end;
      font-size: var(--size-xs);
    }

    .num-col { padding-left: 0; }
    .page-head .hint { font-size: var(--size-xs); }
  }
</style>
