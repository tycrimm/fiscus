---
import { env } from 'cloudflare:workers';
import { db } from '../../db';
import { getPrivateInvestment, privateInvestmentValueSeries } from '../../ops/reads';
import { fmtUSD, fmtDate, prettyKind, pluralize } from '../../lib/format';
import { irr, type Cashflow } from '../../lib/irr';
import { bandFor, effectiveStage, applyBand, STAGE_LABEL, type Stage } from '../../lib/scenarios';
import Shell from '../../layouts/Shell.astro';
import PrivateInvestmentChart from '../../components/PrivateInvestmentChart.astro';

const { id } = Astro.params;
if (!id) return new Response('Not found', { status: 404 });

const d = db(env.DB);

let detail: Awaited<ReturnType<typeof getPrivateInvestment>>;
try {
  detail = await getPrivateInvestment(d, id);
} catch {
  return new Response('Not found', { status: 404 });
}

const series = await privateInvestmentValueSeries(d, id);

const asset = detail.asset as {
  id: string;
  kind: string;
  name: string;
  notes: string | null;
  owner: 'tyler' | 'julianne' | 'joint';
  stage: Stage | null;
  bear_pct: number | null;
  bull_pct: number | null;
};

type Inv = {
  id: string;
  security_type: string | null;
  round_label: string | null;
  shares: number | null;
  price_per_share_cents: number | null;
  cost_basis_cents: number;
  entry_date: number;
  funded_at: number | null;
  derived_value_cents: number | null;
};
type Val = {
  id: string;
  investment_id: string | null;
  as_of: number;
  value_cents: number;
  basis: string | null;
  note: string | null;
};
type Fund = {
  role: string;
  committed_cents: number;
  called_cents: number;
  distributed_cents: number;
  carry_pct: number | null;
  carry_vested_pct: number | null;
} | null;

const investments = detail.investments as unknown as Inv[];
const valuations = detail.valuations as unknown as Val[];
const fund = detail.fund_details as unknown as Fund;

// Sort rounds chronologically (oldest first) for the rounds table.
const rounds = [...investments].sort((a, b) => a.entry_date - b.entry_date);

// Trust the SQL-computed totals — they match listPrivateInvestments' semantic
// (latest-per-leaf summed, asset-level marks included). Summing per-round
// latest_value_cents would miss asset-level marks where investment_id IS NULL.
const currentValueCents = detail.current_value_cents;
const costBasisCents = detail.cost_basis_cents;
const outstandingCents = detail.outstanding_cost_basis_cents;
const gainCents = currentValueCents - costBasisCents;
const gainPct = costBasisCents > 0 ? gainCents / costBasisCents : 0;
const gainPos = gainCents >= 0;
const moic = costBasisCents > 0 ? currentValueCents / costBasisCents : null;

// IRR: dated negative cashflows per round (skipping zero-basis rounds, e.g.
// equity grants, and pending/uncalled tranches whose cash hasn't moved),
// terminal positive at today using the latest mark. Anchoring the terminal at
// today — not the mark date — lets the rate decay naturally while a mark
// goes stale. Always computed when derivable; the days-held indicator next to
// the rate signals when a number is extrapolated from a short window (e.g.
// 4679% over 207d reads honestly once you see "207d"). Suppressed only when
// truly undefined: funds (no dated calls/distributions), no contributions, or
// same-day cashflows.
const nowSec = Math.floor(Date.now() / 1000);
const contribFlows: Cashflow[] = fund
  ? []
  : investments
      .filter((r) => r.cost_basis_cents > 0 && r.funded_at != null)
      .map((r) => ({ t_sec: r.funded_at ?? r.entry_date, amount_cents: -r.cost_basis_cents }));
const earliestContribSec = contribFlows.length > 0
  ? Math.min(...contribFlows.map((c) => c.t_sec))
  : null;
const heldDays = earliestContribSec != null
  ? Math.floor((nowSec - earliestContribSec) / 86400)
  : 0;
const irrPct = contribFlows.length > 0 && currentValueCents > 0 && heldDays >= 1
  ? irr([...contribFlows, { t_sec: nowSec, amount_cents: currentValueCents }])
  : null;
const irrPos = (irrPct ?? 0) >= 0;
const heldLabel = heldDays >= 365
  ? `${(heldDays / 365).toFixed(1)}y held`
  : `${heldDays}d held`;

// Scenario band — bear/bull around the expected current value, driven by
// stage (or kind fallback) with per-asset overrides when set.
const stageKey = effectiveStage({
  kind: asset.kind,
  stage: asset.stage,
  bear_pct: asset.bear_pct,
  bull_pct: asset.bull_pct,
});
const band = bandFor({
  kind: asset.kind,
  stage: asset.stage,
  bear_pct: asset.bear_pct,
  bull_pct: asset.bull_pct,
});
const { bear_cents: bearCents, bull_cents: bullCents } = applyBand(currentValueCents, band);
const bearLabel = `${(band.bear_mult * 100).toFixed(0)}%`;
const bullLabel = band.bull_mult >= 2
  ? `${band.bull_mult.toFixed(1)}×`
  : `${(band.bull_mult * 100).toFixed(0)}%`;
const stageOverridden = asset.bear_pct != null || asset.bull_pct != null;

// Cumulative asset total at each distinct as_of for per-mark deltas.
const cumulativeByAsOf = new Map<number, number>();
for (const p of series) cumulativeByAsOf.set(p.as_of, p.value_cents);
const sortedAsOfs = [...cumulativeByAsOf.keys()].sort((a, b) => a - b);
const prevCumulative = new Map<number, number>();
for (let i = 0; i < sortedAsOfs.length; i++) {
  prevCumulative.set(sortedAsOfs[i], i === 0 ? 0 : cumulativeByAsOf.get(sortedAsOfs[i - 1])!);
}

// Index investments by id so valuations can show which round they mark.
const invById = new Map(investments.map((r) => [r.id, r]));

const fmtPPS = (cents: number | null) =>
  cents == null ? '—' : `$${(cents / 100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
const fmtShares = (n: number | null) =>
  n == null ? '—' : n.toLocaleString('en-US');
const signedUSD = (cents: number) => (cents >= 0 ? '+' : '−') + fmtUSD.format(Math.abs(cents) / 100);
const signedPct = (pct: number) => (pct >= 0 ? '+' : '−') + (Math.abs(pct) * 100).toFixed(1) + '%';

const debugPayload = {
  generated_at: new Date().toISOString(),
  now_sec: nowSec,
  asset,
  fund_details: fund,
  investments,
  valuations,
  series,
  totals: {
    current_value_cents: currentValueCents,
    cost_basis_cents: costBasisCents,
    gain_cents: gainCents,
    gain_pct: gainPct,
    moic,
  },
  irr: {
    earliest_contrib_sec: earliestContribSec,
    held_days: heldDays,
    cashflows: contribFlows.length > 0
      ? [...contribFlows, { t_sec: nowSec, amount_cents: currentValueCents }]
      : [],
    result_pct: irrPct,
    suppressed_reason: fund
      ? 'fund'
      : contribFlows.length === 0
        ? 'no_contributions'
        : currentValueCents <= 0
          ? 'no_value'
          : heldDays < 1
            ? 'same_day'
            : null,
  },
};
---
<Shell title={asset.name}>
  <div class="detail">
    <header class="detail-head">
      <div class="head-top">
        <a href="/" class="back">← back</a>
      </div>
      <h1>{asset.name}</h1>
      <div class="meta">
        <span class="kind">{prettyKind(asset.kind)}</span>
        <span class="dot">·</span>
        <span>{pluralize(investments.length, 'round')}</span>
      </div>
      {asset.notes && <p class="notes">{asset.notes}</p>}
    </header>

    <section class="stats">
      <div class="stat">
        <div class="stat-label">current value</div>
        <div class="stat-val num">{fmtUSD.format(currentValueCents / 100)}</div>
      </div>
      <div class="stat">
        <div class="stat-label">cost basis</div>
        <div class="stat-val num muted">
          {fmtUSD.format(costBasisCents / 100)}
          {outstandingCents > 0 && (
            <span class="gain-pct" title="Allocation committed but not yet wired (capital call pending)">
              + {fmtUSD.format(outstandingCents / 100)} uncalled
            </span>
          )}
        </div>
      </div>
      <div class="stat">
        <div class="stat-label">gain</div>
        <div class={`stat-val num ${gainPos ? 'pos' : 'neg'}`}>
          {signedUSD(gainCents)}
          <span class="gain-pct">{signedPct(gainPct)}</span>
        </div>
      </div>
      <div class="stat">
        <div class="stat-label">MOIC</div>
        {moic != null ? (
          <div class={`stat-val num ${moic >= 1 ? 'pos' : 'neg'}`}>{moic.toFixed(2)}×</div>
        ) : (
          <div class="stat-val num muted">—</div>
        )}
      </div>
      <div class="stat">
        <div class="stat-label">IRR</div>
        {irrPct != null ? (
          <div class={`stat-val num ${irrPos ? 'pos' : 'neg'}`}>
            {signedPct(irrPct)}
            <span class="gain-pct">{heldLabel}</span>
          </div>
        ) : (
          <div class="stat-val num muted">—</div>
        )}
      </div>
    </section>

    <div class="chart-row">
      <div class="chart-col">
        <PrivateInvestmentChart
          series={series}
          bearMult={band.bear_mult}
          bullMult={band.bull_mult}
        />
      </div>
      <aside class="scenario">
        <div class="scenario-head">
          <span class="scenario-label">scenario</span>
          <span class="stage-badge">{STAGE_LABEL[stageKey]}{stageOverridden && ' · override'}</span>
        </div>
        <div class="scenario-row top">
          <div class="scenario-tag">bull <span class="mult">{bullLabel}</span></div>
          <div class="scenario-val num muted">{fmtUSD.format(bullCents / 100)}</div>
        </div>
        <div class="scenario-row mid">
          <div class="scenario-tag">current</div>
          <div class="scenario-val num">{fmtUSD.format(currentValueCents / 100)}</div>
        </div>
        <div class="scenario-row bot">
          <div class="scenario-tag">bear <span class="mult">{bearLabel}</span></div>
          <div class="scenario-val num muted">{fmtUSD.format(bearCents / 100)}</div>
        </div>
      </aside>
    </div>

    {fund && (
      <section class="block">
        <h2>Fund terms</h2>
        <dl class="fund-grid">
          <dt>Role</dt><dd>{fund.role.toUpperCase()}</dd>
          <dt>Committed</dt><dd class="num">{fmtUSD.format(fund.committed_cents / 100)}</dd>
          <dt>Called</dt><dd class="num">{fmtUSD.format(fund.called_cents / 100)}</dd>
          <dt>Distributed</dt><dd class="num">{fmtUSD.format(fund.distributed_cents / 100)}</dd>
          {fund.carry_pct != null && (<><dt>Carry</dt><dd class="num">{(fund.carry_pct * 100).toFixed(2)}%</dd></>)}
          {fund.carry_vested_pct != null && (<><dt>Vested</dt><dd class="num">{(fund.carry_vested_pct * 100).toFixed(2)}%</dd></>)}
        </dl>
      </section>
    )}

    {rounds.length > 0 && (
      <section class="block">
        <h2>Rounds</h2>
        <table class="ledger-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Round</th>
              <th>Security</th>
              <th class="num-col">Shares</th>
              <th class="num-col">PPS</th>
              <th class="num-col">Cost Basis</th>
              <th class="num-col">Current</th>
              <th class="num-col delta-col">Δ</th>
              <th class="num-col">MOIC</th>
            </tr>
          </thead>
          <tbody>
            {rounds.map((r) => {
              const cur = r.derived_value_cents;
              const pending = r.funded_at == null;
              const delta = cur == null ? 0 : cur - r.cost_basis_cents;
              const dpos = delta >= 0;
              const moic = cur != null && r.cost_basis_cents > 0 ? cur / r.cost_basis_cents : null;
              return (
                <tr class:list={[{ pending }]}>
                  <td>
                    {fmtDate(r.entry_date)}
                    {pending && <span class="pending-tag" title="Allocation committed but wire not yet sent">pending</span>}
                  </td>
                  <td>{r.round_label ?? '—'}</td>
                  <td>{r.security_type ?? '—'}</td>
                  <td class="num-col">{fmtShares(r.shares)}</td>
                  <td class="num-col">{fmtPPS(r.price_per_share_cents)}</td>
                  <td class="num-col">{fmtUSD.format(r.cost_basis_cents / 100)}</td>
                  <td class="num-col">{cur == null ? '—' : fmtUSD.format(cur / 100)}</td>
                  <td class="num-col delta-col">
                    {cur != null && delta !== 0 ? (
                      <span class={dpos ? 'pos' : 'neg'}>{signedUSD(delta)}</span>
                    ) : (
                      <span class="muted">—</span>
                    )}
                  </td>
                  <td class:list={['num-col', { muted: moic != null && Math.abs(moic - 1) < 0.01 }]}>
                    {moic == null ? '—' : `${moic.toFixed(2)}×`}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </section>
    )}

    {valuations.length > 0 && (
      <section class="block">
        <h2>Valuation marks</h2>
        <table class="ledger-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Basis</th>
              <th>Applies to</th>
              <th>Note</th>
              <th class="num-col">Value</th>
              <th class="num-col">Δ total</th>
            </tr>
          </thead>
          <tbody>
            {valuations.map((v) => {
              const inv = v.investment_id ? invById.get(v.investment_id) : null;
              const label = inv
                ? (inv.round_label ?? inv.security_type ?? 'Round')
                : 'Asset-level';
              // Delta = change in the asset's *cumulative* total at this mark's
              // as_of vs the previous distinct as_of. When multiple marks land
              // on the same day (e.g. entry + mark-up), they share the cumulative
              // value, so the first row of the day gets the delta and the rest
              // show no change. First mark ever shows no delta (no prior state).
              const cumulativeHere = cumulativeByAsOf.get(v.as_of) ?? 0;
              const cumulativePrev = prevCumulative.get(v.as_of) ?? 0;
              const deltaTotal = cumulativeHere - cumulativePrev;
              const hasDelta = cumulativePrev > 0 && deltaTotal !== 0;
              const deltaPct = hasDelta && cumulativePrev > 0 ? deltaTotal / cumulativePrev : 0;
              const dpos = deltaTotal >= 0;
              return (
                <tr>
                  <td>{fmtDate(v.as_of)}</td>
                  <td>{v.basis ?? '—'}</td>
                  <td>{label}</td>
                  <td class="note-cell">{v.note ?? ''}</td>
                  <td class="num-col">{fmtUSD.format(v.value_cents / 100)}</td>
                  <td class="num-col delta-col">
                    {hasDelta ? (
                      <div class={`delta-cell ${dpos ? 'pos' : 'neg'}`}>
                        <div>{signedUSD(deltaTotal)}</div>
                        <div class="delta-pct">{signedPct(deltaPct)}</div>
                      </div>
                    ) : (
                      <span class="muted">—</span>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </section>
    )}

    <footer class="detail-foot">
      <button
        id="debug-copy"
        type="button"
        class="debug-btn"
        data-payload={JSON.stringify(debugPayload)}
      >copy debug</button>
    </footer>
  </div>

  <script>
    const btn = document.getElementById('debug-copy');
    if (btn instanceof HTMLButtonElement) {
      btn.addEventListener('click', async () => {
        const payload = btn.dataset.payload ?? '';
        const original = btn.textContent ?? 'copy debug';
        try {
          await navigator.clipboard.writeText(payload);
          btn.textContent = 'copied';
        } catch {
          btn.textContent = 'failed';
        }
        setTimeout(() => { btn.textContent = original; }, 1500);
      });
    }
  </script>
</Shell>

<style>
  .detail {
    display: grid;
    gap: var(--space-6);
  }
  .detail-head { display: grid; gap: var(--space-2); }
  .head-top { display: flex; }
  .back {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    text-decoration: none;
  }
  .back:hover { color: var(--fg); }
  h1 {
    font-size: var(--size-2xl);
    letter-spacing: -0.02em;
    font-weight: 500;
    margin: 0;
    text-transform: none;
  }
  .meta {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
  }
  .meta .dot { opacity: 0.55; }
  .meta .owner { color: var(--fg); font-weight: 500; }
  .meta .owner.joint { color: var(--fg-muted); font-weight: 400; }
  .notes {
    font-size: var(--size-sm);
    color: var(--fg-muted);
    margin: var(--space-2) 0 0;
    max-width: 48rem;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-4);
    padding: var(--space-4) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .stat-label {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    margin-bottom: var(--space-1);
  }
  .stat-val {
    font-size: var(--size-xl);
    font-weight: 500;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .stat-val.muted { color: var(--fg-muted); font-weight: 400; }
  .stat-val.pos { color: var(--pos); }
  .stat-val.neg { color: var(--neg); }
  .gain-pct {
    margin-left: var(--space-2);
    font-size: var(--size-sm);
    color: var(--fg-muted);
  }

  .block { display: grid; gap: var(--space-3); }
  .block h2 {
    font-size: var(--size-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
    margin: 0;
  }

  .chart-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 14rem;
    gap: var(--space-6);
    align-items: start;
  }
  .chart-col { min-width: 0; }

  .scenario {
    display: grid;
    grid-auto-rows: min-content;
    gap: 0;
    padding-left: var(--space-4);
    border-left: 1px solid var(--rule);
  }
  .scenario-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--space-2);
  }
  .scenario-label {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
  }
  .stage-badge {
    font-size: var(--size-xs);
    letter-spacing: 0.08em;
    color: var(--fg);
    font-weight: 500;
    text-transform: uppercase;
  }
  .scenario-row {
    display: grid;
    grid-template-columns: auto auto;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-2) 0;
    gap: var(--space-3);
  }
  .scenario-row + .scenario-row { border-top: 1px dashed var(--rule); }
  .scenario-row.mid .scenario-val { font-weight: 500; color: var(--fg); }
  .scenario-tag {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    display: inline-flex;
    gap: var(--space-1);
    align-items: baseline;
  }
  .scenario-tag .mult {
    opacity: 0.7;
    font-variant-numeric: tabular-nums;
  }
  .scenario-val {
    font-size: var(--size-base);
    font-variant-numeric: tabular-nums;
  }
  .scenario-val.muted { color: var(--fg-muted); }

  @media (max-width: 52rem) {
    .chart-row {
      grid-template-columns: 1fr;
    }
    .scenario {
      padding-left: 0;
      border-left: none;
      border-top: 1px solid var(--rule);
      padding-top: var(--space-3);
    }
  }

  .ledger-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--size-sm);
    font-variant-numeric: tabular-nums;
  }
  .ledger-table th {
    text-align: left;
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    font-weight: 500;
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--rule);
    white-space: nowrap;
  }
  .ledger-table td {
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--rule);
    vertical-align: baseline;
  }
  .ledger-table tbody tr:last-child td { border-bottom: none; }
  .ledger-table .num-col {
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  /* Δ columns: smaller, muted by default; .pos/.neg override the color. */
  .ledger-table .delta-col {
    font-size: var(--size-xs);
    color: var(--fg-muted);
  }
  .ledger-table .delta-col .pos { color: var(--pos); }
  .ledger-table .delta-col .neg { color: var(--neg); }
  /* Stacked $ + % delta for valuation marks. Each line right-aligns via the
     inherited num-col text-align; grid keeps them vertically compact. */
  .ledger-table .delta-cell {
    display: grid;
    gap: 0;
    line-height: 1.25;
  }
  .ledger-table .delta-cell .delta-pct {
    font-size: var(--size-xs);
    opacity: 0.7;
  }
  .note-cell {
    color: var(--fg-muted);
    font-size: var(--size-xs);
    max-width: 22rem;
  }
  /* Pending tranches: italicize cost basis and gray out the row to signal
     "committed but wire not sent". The "pending" tag inline next to the date
     is the explicit marker. */
  .ledger-table tr.pending td { color: var(--fg-muted); font-style: italic; }
  .ledger-table .pending-tag {
    margin-left: var(--space-2);
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-style: normal;
    color: var(--fg-muted);
    border: 1px solid var(--rule);
    padding: 0 var(--space-1);
  }

  .fund-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-1) var(--space-4);
    font-size: var(--size-sm);
    margin: 0;
  }
  .fund-grid dt {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
  }
  .fund-grid dd {
    margin: 0;
    font-variant-numeric: tabular-nums;
  }

  .detail-foot {
    display: flex;
    justify-content: flex-end;
    padding-top: var(--space-4);
    border-top: 1px solid var(--rule);
  }
  .debug-btn {
    font-family: inherit;
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
