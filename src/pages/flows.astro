---
import { env } from 'cloudflare:workers';
import { db } from '../db';
import { listAccounts } from '../ops/reads';
import { forecastFlows, listExpectedFlows } from '../ops/flows';
import type { Direction, Cadence, Owner } from '../ops/flows';
import { fmtUSD, fmtDate } from '../lib/format';
import Shell from '../layouts/Shell.astro';

const d = db(env.DB);
const [accounts, flows, projected] = await Promise.all([
  listAccounts(d),
  listExpectedFlows(d),
  forecastFlows(d, 365),
]);

const lastSyncedAt = accounts.reduce<number | null>(
  (max, a) => (a.latest_as_of && (!max || a.latest_as_of > max) ? a.latest_as_of : max),
  null,
);

const notesByFlowId = new Map(flows.map((f) => [f.id, f.notes]));

// ─── 12-month monthly rollup ────────────────────────────────────────────────
type Bucket = { key: string; label: string; inCents: number; outCents: number };

const monthLabel = new Intl.DateTimeFormat('en-US', {
  month: 'short', year: 'numeric', timeZone: 'UTC',
});
const dayLabel = new Intl.DateTimeFormat('en-US', {
  month: 'short', day: 'numeric', timeZone: 'UTC',
});
const bucketKey = (sec: number) => {
  const d = new Date(sec * 1000);
  return `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}`;
};

const today = new Date();
const anchor = new Date(Date.UTC(today.getUTCFullYear(), today.getUTCMonth(), 1));
const buckets: Bucket[] = [];
for (let i = 0; i < 12; i++) {
  const dt = new Date(Date.UTC(anchor.getUTCFullYear(), anchor.getUTCMonth() + i, 1));
  const key = `${dt.getUTCFullYear()}-${String(dt.getUTCMonth() + 1).padStart(2, '0')}`;
  buckets.push({ key, label: monthLabel.format(dt), inCents: 0, outCents: 0 });
}
const byKey = new Map(buckets.map((b) => [b.key, b]));

for (const p of projected) {
  const b = byKey.get(bucketKey(p.date));
  if (!b) continue;
  if (p.direction === 'inflow') b.inCents += p.amountExpectedCents;
  else b.outCents += p.amountExpectedCents;
}

const totalIn = buckets.reduce((s, b) => s + b.inCents, 0);
const totalOut = buckets.reduce((s, b) => s + b.outCents, 0);
const totalNet = totalIn - totalOut;

// Break out the one-off contribution so the header stats show what part of
// the total is one-time vs steady-state.
const oneOffIn = projected
  .filter((p) => p.cadence === 'once' && p.direction === 'inflow')
  .reduce((s, p) => s + p.amountExpectedCents, 0);
const oneOffOut = projected
  .filter((p) => p.cadence === 'once' && p.direction === 'outflow')
  .reduce((s, p) => s + p.amountExpectedCents, 0);
const oneOffNet = oneOffIn - oneOffOut;

// ─── One-offs within window ─────────────────────────────────────────────────
const oneOffs = projected
  .filter((p) => p.cadence === 'once')
  .sort((a, b) => a.date - b.date);

// ─── Parent flows list (consolidated) ───────────────────────────────────────
// Collapse paired flows sharing a base label (e.g. "SHV paycheck (mid-month)"
// + "SHV paycheck (month-end)" → one "SHV paycheck" row summing both halves).
type Component = { nextExpectedAt: number; amountExpectedCents: number; suffix: string };
type FlowRow = {
  id: string;
  label: string;
  direction: Direction;
  cadence: Cadence;
  owner: Owner;
  amountExpectedCents: number;
  amountLowCents: number | null;
  amountHighCents: number | null;
  nextExpectedAt: number;
  notes: string | null;
  components: Component[];
};

const stripSuffix = (s: string) => s.replace(/\s*\([^)]*\)\s*$/, '').trim();
const extractSuffix = (s: string) => {
  const m = s.match(/\(([^)]*)\)\s*$/);
  return m ? m[1] : '';
};

const grouped = new Map<string, typeof flows>();
for (const f of flows) {
  const key = `${stripSuffix(f.label)}|${f.direction}|${f.cadence}|${f.owner}`;
  const arr = grouped.get(key) ?? [];
  arr.push(f);
  grouped.set(key, arr);
}

const flowRows: FlowRow[] = [];
for (const group of grouped.values()) {
  if (group.length === 1) {
    const f = group[0];
    flowRows.push({
      id: f.id, label: f.label, direction: f.direction, cadence: f.cadence, owner: f.owner,
      amountExpectedCents: f.amountExpectedCents,
      amountLowCents: f.amountLowCents, amountHighCents: f.amountHighCents,
      nextExpectedAt: f.nextExpectedAt, notes: f.notes,
      components: [],
    });
  } else {
    const base = stripSuffix(group[0].label);
    const components: Component[] = group
      .slice()
      .sort((a, b) => a.nextExpectedAt - b.nextExpectedAt)
      .map((f) => ({
        nextExpectedAt: f.nextExpectedAt,
        amountExpectedCents: f.amountExpectedCents,
        suffix: extractSuffix(f.label),
      }));
    const allLow = group.every((f) => f.amountLowCents != null);
    const allHigh = group.every((f) => f.amountHighCents != null);
    flowRows.push({
      id: group.map((f) => f.id).join(','),
      label: base,
      direction: group[0].direction,
      cadence: group[0].cadence,
      owner: group[0].owner,
      amountExpectedCents: group.reduce((s, f) => s + f.amountExpectedCents, 0),
      amountLowCents: allLow ? group.reduce((s, f) => s + (f.amountLowCents ?? 0), 0) : null,
      amountHighCents: allHigh ? group.reduce((s, f) => s + (f.amountHighCents ?? 0), 0) : null,
      nextExpectedAt: Math.min(...group.map((f) => f.nextExpectedAt)),
      notes: group.find((f) => f.notes)?.notes ?? null,
      components,
    });
  }
}

// Cadence → occurrences per month averaged over a year. Used for sort + display.
const CADENCE_MULT_PER_MONTH: Record<string, number> = {
  weekly: 52 / 12,
  biweekly: 26 / 12,
  monthly: 1,
  quarterly: 1 / 3,
  annual: 1 / 12,
  once: 0,
};
const monthlyAvgCents = (r: FlowRow) => {
  const perOccurrence = r.components.length > 0
    ? r.amountExpectedCents / r.components.length
    : r.amountExpectedCents;
  const mult = (CADENCE_MULT_PER_MONTH[r.cadence] ?? 0) * Math.max(r.components.length, 1);
  return Math.round(perOccurrence * mult);
};

// Recurring (main list) vs one-off (its own section below).
// Sort: inflow → outflow, then cadence (most-frequent first), then amount desc.
const CADENCE_ORDER: Record<string, number> = {
  weekly: 0, biweekly: 1, monthly: 2, quarterly: 3, annual: 4,
};
const recurringRows = flowRows
  .filter((r) => r.cadence !== 'once')
  .sort((a, b) => {
    if (a.direction !== b.direction) return a.direction === 'inflow' ? -1 : 1;
    const ca = CADENCE_ORDER[a.cadence] ?? 99;
    const cb = CADENCE_ORDER[b.cadence] ?? 99;
    if (ca !== cb) return ca - cb;
    return Math.abs(b.amountExpectedCents) - Math.abs(a.amountExpectedCents);
  });

// Named cadence for known merged multipliers — "annual ×2" is gibberish when
// "semiannual" is a real word. Fall back to "<cadence> ×N" for anything else.
const NAMED_MULTIPLIERS: Record<string, Record<number, string>> = {
  monthly: { 2: 'semimonthly' },
  annual: { 2: 'semiannual' },
};
const cadenceLabelFor = (r: FlowRow) => {
  const n = r.components.length;
  if (n <= 1) return r.cadence;
  return NAMED_MULTIPLIERS[r.cadence]?.[n] ?? `${r.cadence} ×${n}`;
};

// ─── Formatting helpers ─────────────────────────────────────────────────────
const fmtAbs = (cents: number) => fmtUSD.format(Math.abs(cents) / 100);
const fmtIn = (cents: number) => `+${fmtUSD.format(cents / 100)}`;
const fmtOut = (cents: number) => `−${fmtUSD.format(cents / 100)}`;
const fmtNet = (cents: number) =>
  cents === 0 ? fmtUSD.format(0) : `${cents >= 0 ? '+' : '−'}${fmtAbs(cents)}`;
const fmtSigned = (cents: number, dir: Direction) =>
  `${dir === 'inflow' ? '+' : '−'}${fmtUSD.format(cents / 100)}`;
---
<Shell title="flows" lastSyncedAt={lastSyncedAt}>
  {flows.length === 0 ? (
    <p class="empty">NO EXPECTED FLOWS YET — ASK AN AGENT TO ADD ONE.</p>
  ) : (
    <section class="page">
      <header class="head">
        <div class="title">
          <div class="eyebrow">next 12 months</div>
          <h1>Flows</h1>
        </div>
        <dl class="stats">
          <div class="stat">
            <dt>in</dt>
            <dd class="num pos">{fmtIn(totalIn)}</dd>
            {oneOffIn > 0 && <div class="stat-foot muted">incl. {fmtIn(oneOffIn)} one-offs</div>}
          </div>
          <div class="stat">
            <dt>out</dt>
            <dd class="num neg">{fmtOut(totalOut)}</dd>
            {oneOffOut > 0 && <div class="stat-foot muted">incl. {fmtOut(oneOffOut)} one-offs</div>}
          </div>
          <div class="stat">
            <dt>net</dt>
            <dd class={`num ${totalNet >= 0 ? 'pos' : 'neg'}`}>{fmtNet(totalNet)}</dd>
            {oneOffNet !== 0 && <div class="stat-foot muted">incl. {fmtNet(oneOffNet)} one-offs</div>}
          </div>
        </dl>
      </header>

      <div class="split">
        <section class="col">
          <h2>by month</h2>
          <table class="flows-tbl compact">
            <thead>
              <tr>
                <th>month</th>
                <th class="num-col">in</th>
                <th class="num-col">out</th>
                <th class="num-col">net</th>
              </tr>
            </thead>
            <tbody>
              {buckets.map((b) => {
                const net = b.inCents - b.outCents;
                return (
                  <tr>
                    <td class="month">{b.label}</td>
                    <td class="num-col">
                      {b.inCents > 0 ? <span class="pos">{fmtIn(b.inCents)}</span> : <span class="muted">—</span>}
                    </td>
                    <td class="num-col">
                      {b.outCents > 0 ? <span class="neg">{fmtOut(b.outCents)}</span> : <span class="muted">—</span>}
                    </td>
                    <td class={`num-col ${net >= 0 ? 'pos' : 'neg'}`}>{fmtNet(net)}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </section>

        <section class="col">
          {(() => {
            const inMonthly = recurringRows
              .filter((r) => r.direction === 'inflow')
              .reduce((s, r) => s + monthlyAvgCents(r), 0);
            const outMonthly = recurringRows
              .filter((r) => r.direction === 'outflow')
              .reduce((s, r) => s + monthlyAvgCents(r), 0);
            const netMonthly = inMonthly - outMonthly;
            const inYearly = inMonthly * 12;
            const outYearly = outMonthly * 12;
            const netYearly = netMonthly * 12;
            return (
              <>
                <div class="rec-head">
                  <h2>recurring ({recurringRows.length})</h2>
                  <dl class="rec-stats">
                    <div class="rec-stat">
                      <dt>in</dt>
                      <dd class="num pos">{fmtIn(inMonthly)}<span class="per muted"> /mo</span></dd>
                      <dd class="num pos sub">{fmtIn(inYearly)}<span class="per muted"> /yr</span></dd>
                    </div>
                    <div class="rec-stat">
                      <dt>out</dt>
                      <dd class="num neg">{fmtOut(outMonthly)}<span class="per muted"> /mo</span></dd>
                      <dd class="num neg sub">{fmtOut(outYearly)}<span class="per muted"> /yr</span></dd>
                    </div>
                    <div class="rec-stat">
                      <dt>net</dt>
                      <dd class={`num ${netMonthly >= 0 ? 'pos' : 'neg'}`}>{fmtNet(netMonthly)}<span class="per muted"> /mo</span></dd>
                      <dd class={`num ${netYearly >= 0 ? 'pos' : 'neg'} sub`}>{fmtNet(netYearly)}<span class="per muted"> /yr</span></dd>
                    </div>
                  </dl>
                </div>
                <table class="flows-tbl">
                  <thead>
                    <tr>
                      <th>label</th>
                      <th>cadence</th>
                      <th class="num-col">expected</th>
                      <th class="num-col">monthly</th>
                      <th class="num-col">yearly</th>
                      <th class="num-col">next</th>
                    </tr>
                  </thead>
                  <tbody>
                    {recurringRows.map((r) => {
                      const cls = r.direction === 'inflow' ? 'pos' : 'neg';
                      const monthly = monthlyAvgCents(r);
                      const yearly = monthly * 12;
                      // "semimonthly $30,000" reads wrong — amount should be per-occurrence
                      // so the cadence word + amount reads naturally ($15k twice a month).
                      const perOccurrence = r.components.length > 1
                        ? Math.round(r.amountExpectedCents / r.components.length)
                        : r.amountExpectedCents;
                      return (
                        <tr>
                          <td><div class="lbl">{r.label}</div></td>
                          <td class="muted small-caps nowrap">{cadenceLabelFor(r)}</td>
                          <td class="num-col">
                            <span class={cls}>{fmtSigned(perOccurrence, r.direction)}</span>
                          </td>
                          <td class="num-col">
                            <span class={cls}>{fmtSigned(monthly, r.direction)}</span>
                          </td>
                          <td class="num-col">
                            <span class={cls}>{fmtSigned(yearly, r.direction)}</span>
                          </td>
                          <td class="muted num-col nowrap">{fmtDate(r.nextExpectedAt)}</td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </>
            );
          })()}

          {oneOffs.length > 0 && (
            <div class="oneoffs">
              <h3>one-offs ({oneOffs.length})</h3>
              <ul class="oneoff-list">
                {oneOffs.map((p) => {
                  const sign = p.direction === 'inflow' ? '+' : '−';
                  const cls = p.direction === 'inflow' ? 'pos' : 'neg';
                  const hasRange = p.amountLowCents != null || p.amountHighCents != null;
                  const fmtSignedOne = (c: number) => `${sign}${fmtUSD.format(c / 100)}`;
                  const fmtUnsigned = (c: number) => fmtUSD.format(c / 100);
                  const note = notesByFlowId.get(p.flowId);
                  return (
                    <li>
                      <span class="oo-date muted nowrap">{fmtDate(p.date)}</span>
                      <span class="oo-label">{p.label}</span>
                      <span class={`oo-amount num nowrap ${cls}`}>
                        {hasRange ? (
                          <>
                            {fmtSignedOne(p.amountExpectedCents)}
                            <span class="oo-range muted">
                              {' '}({p.amountLowCents != null ? fmtUnsigned(p.amountLowCents) : '—'}
                              {' / '}
                              {p.amountHighCents != null ? fmtUnsigned(p.amountHighCents) : '—'})
                            </span>
                          </>
                        ) : (
                          fmtSignedOne(p.amountExpectedCents)
                        )}
                      </span>
                      {note && <span class="oo-note muted">{note}</span>}
                    </li>
                  );
                })}
              </ul>
            </div>
          )}
        </section>
      </div>
    </section>
  )}
</Shell>

<style>
  .head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-6);
    align-items: end;
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--rule-strong);
  }
  .title .eyebrow {
    font-size: var(--size-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
  .title h1 {
    font-size: var(--size-2xl);
    font-weight: 500;
    letter-spacing: -0.025em;
    text-transform: none;
    margin-top: var(--space-1);
  }

  .stats {
    display: grid;
    grid-auto-flow: column;
    gap: var(--space-8);
    margin: 0;
    font-variant-numeric: tabular-nums;
  }
  .stat { display: grid; gap: 2px; margin: 0; }
  .stat dt {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
  }
  .stat dd {
    margin: 0;
    font-size: var(--size-lg);
    font-weight: 500;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: var(--space-8);
    align-items: start;
    margin-top: var(--space-6);
  }
  .col h2 {
    font-size: var(--size-xs);
    letter-spacing: 0.12em;
    color: var(--fg-muted);
    margin-bottom: var(--space-2);
  }

  .oneoffs { margin-top: var(--space-8); }
  .oneoffs h3 {
    font-size: var(--size-xs);
    letter-spacing: 0.12em;
    color: var(--fg-muted);
    margin-bottom: var(--space-1);
  }

  table.flows-tbl {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--size-sm);
    font-variant-numeric: tabular-nums;
  }
  table.flows-tbl th,
  table.flows-tbl td {
    padding: var(--space-3) var(--space-2);
    text-align: left;
    vertical-align: baseline;
  }
  table.flows-tbl.compact th,
  table.flows-tbl.compact td {
    padding: var(--space-2) var(--space-2);
  }
  table.flows-tbl .nowrap { white-space: nowrap; }
  table.flows-tbl .next-col { font-size: var(--size-xs); }
  table.flows-tbl .next-col div + div { margin-top: 2px; }
  table.flows-tbl thead th {
    font-weight: 500;
    color: var(--fg-muted);
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 1px solid var(--rule-strong);
    padding-bottom: var(--space-2);
  }
  table.flows-tbl tbody td { border-bottom: 1px solid var(--rule); }
  table.flows-tbl .num-col { text-align: right; white-space: nowrap; }
  table.flows-tbl .month {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: var(--size-xs);
    color: var(--fg-muted);
  }
  table.flows-tbl .lbl { }
  table.flows-tbl .note {
    font-size: var(--size-xs);
    color: var(--fg-muted);
    margin-top: 2px;
    max-width: 42rem;
  }
  table.flows-tbl .sub-meta {
    font-size: var(--size-xs);
    margin-top: 2px;
  }
  table.flows-tbl .note-inline {
    font-size: var(--size-xs);
  }
  table.flows-tbl .small-caps {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: var(--size-xs);
  }
  table.flows-tbl .range {
    font-size: var(--size-xs);
    margin-top: 2px;
  }
  table.flows-tbl .suffix {
    font-size: var(--size-xs);
    color: var(--fg-muted);
  }
  .rec-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-6);
    align-items: end;
    padding-bottom: var(--space-4);
    margin-bottom: var(--space-3);
    border-bottom: 1px solid var(--rule-strong);
  }
  .rec-head h2 {
    font-size: var(--size-xs);
    letter-spacing: 0.12em;
    color: var(--fg-muted);
    margin: 0;
  }
  .rec-stats {
    display: grid;
    grid-auto-flow: column;
    gap: var(--space-6);
    margin: 0;
    font-variant-numeric: tabular-nums;
  }
  .rec-stat { display: grid; gap: 2px; margin: 0; justify-items: end; }
  .rec-stat dt {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
  }
  .rec-stat dd {
    margin: 0;
    font-size: var(--size-sm);
    font-weight: 500;
    white-space: nowrap;
  }
  .rec-stat dd.sub { font-size: var(--size-xs); font-weight: 400; }
  .rec-stat .per { font-weight: 400; font-size: var(--size-xs); }

  .stat-foot {
    font-size: var(--size-xs);
    margin-top: 2px;
    text-transform: none;
    letter-spacing: 0;
  }

  ul.oneoff-list { list-style: none; padding: 0; margin: var(--space-2) 0 0; }
  ul.oneoff-list li {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-3);
    align-items: baseline;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--rule);
    font-size: var(--size-sm);
  }
  ul.oneoff-list .oo-date {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  ul.oneoff-list .oo-amount { font-variant-numeric: tabular-nums; }
  ul.oneoff-list .oo-range { font-size: var(--size-xs); }
  ul.oneoff-list .oo-note {
    grid-column: 2 / -1;
    font-size: var(--size-xs);
    margin-top: 2px;
  }

  @media (max-width: 76rem) {
    .split { grid-template-columns: 1fr; }
  }
  @media (max-width: 52rem) {
    .head { grid-template-columns: 1fr; }
    .stats { grid-auto-flow: row; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); }
  }
</style>
