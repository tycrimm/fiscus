---
import { actions } from 'astro:actions';
import Shell from '../../layouts/Shell.astro';

const result = Astro.getActionResult(actions.addAccount);
if (result && !result.error) {
  return Astro.redirect('/');
}
const err = result?.error;
---
<Shell title="add account">
  <h1>add account</h1>

  {err && <p class="err">{err.message}</p>}

  <form method="POST" action={actions.addAccount}>
    <div class="row-2">
      <label>
        institution
        <input name="institutionName" placeholder="Schwab" required autofocus />
      </label>
      <label>
        institution kind
        <select name="institutionKind">
          <option value="bank">bank</option>
          <option value="brokerage" selected>brokerage</option>
          <option value="credit_card">credit card</option>
          <option value="retirement">retirement</option>
          <option value="crypto">crypto</option>
          <option value="other">other</option>
        </select>
      </label>
    </div>

    <div class="row-2">
      <label>
        account name
        <input name="accountName" placeholder="Joint brokerage" required />
      </label>
      <label>
        account kind
        <select name="accountKind">
          <option value="checking">checking</option>
          <option value="savings">savings</option>
          <option value="brokerage" selected>brokerage</option>
          <option value="credit_card">credit card</option>
          <option value="retirement">retirement</option>
          <option value="crypto">crypto</option>
          <option value="loan">loan</option>
          <option value="other">other</option>
        </select>
      </label>
    </div>

    <label>
      current balance (usd)
      <input name="balanceDollars" type="number" step="0.01" placeholder="0.00" required />
    </label>

    <label class="check">
      <input type="checkbox" name="isLiability" />
      this account is a liability (debt) — subtracts from net worth
    </label>

    <div class="actions">
      <button type="submit">add account</button>
      <a href="/" class="muted" style="font-size: var(--size-sm)">cancel</a>
    </div>
  </form>
</Shell>
