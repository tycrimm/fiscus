---
import { env } from 'cloudflare:workers';
import { db } from '../db';
import { netWorth, netWorthSeries, listAccounts, listPrivateInvestments, syncHealth } from '../ops/reads';
import { fmtUSD, fmtUSDsigned, prettyKind, pluralize } from '../lib/format';
import { computeDeltas, computeAllocation, topConcentration, computeChangeAttribution } from '../lib/metrics';
import Shell from '../layouts/Shell.astro';
import LedgerSection from '../components/LedgerSection.astro';
import LedgerRow from '../components/LedgerRow.astro';
import LedgerInstitution from '../components/LedgerInstitution.astro';
import NetWorthChart from '../components/NetWorthChart.astro';
import AllocationMix from '../components/AllocationMix.astro';
import Concentration from '../components/Concentration.astro';
import ChangeAttribution from '../components/ChangeAttribution.astro';

const d = db(env.DB);
const [nw, series, accounts, privateInv, syncIssues] = await Promise.all([
  netWorth(d),
  netWorthSeries(d),
  listAccounts(d),
  listPrivateInvestments(d),
  syncHealth(d),
]);

const cash   = accounts.filter((a) => !a.is_liability && ['checking', 'savings'].includes(a.kind));
const invest = accounts.filter((a) => !a.is_liability && ['brokerage', 'retirement', 'education', 'crypto'].includes(a.kind));
const other  = accounts.filter((a) => !a.is_liability && !['checking', 'savings', 'brokerage', 'retirement', 'education', 'crypto'].includes(a.kind));
const liab   = accounts.filter((a) => !!a.is_liability);
privateInv.sort((a, b) => b.current_value_cents - a.current_value_cents);

type KindLine = { kind: string; count: number; totalCents: number; note: string | null };
type InstGroup = { institution: string; totalCents: number; kinds: KindLine[] };

function rollupByInstitution(rows: typeof accounts): InstGroup[] {
  const insts = new Map<string, InstGroup>();
  for (const r of rows) {
    let g = insts.get(r.institution);
    if (!g) {
      g = { institution: r.institution, totalCents: 0, kinds: [] };
      insts.set(r.institution, g);
    }
    let k = g.kinds.find((x) => x.kind === r.kind);
    if (!k) {
      k = { kind: r.kind, count: 0, totalCents: 0, note: r.note ?? null };
      g.kinds.push(k);
    } else {
      // Multiple accounts in this group — notes only render when the group is a single account.
      k.note = null;
    }
    k.count += 1;
    k.totalCents += r.latest_cents ?? 0;
    g.totalCents += r.latest_cents ?? 0;
  }
  for (const g of insts.values()) {
    g.kinds.sort((a, b) => Math.abs(b.totalCents) - Math.abs(a.totalCents));
  }
  return [...insts.values()].sort((a, b) => Math.abs(b.totalCents) - Math.abs(a.totalCents));
}

const cashInsts   = rollupByInstitution(cash);
const otherInsts  = rollupByInstitution(other);
// Investments + liabilities render as per-account rows (one link per
// account) so each maps 1:1 to a detail page. Sorted by size so the biggest
// position / biggest debt lands on top.
const investRows = [...invest].sort((a, b) => (b.latest_cents ?? 0) - (a.latest_cents ?? 0));
const liabRows = [...liab].sort((a, b) => (b.latest_cents ?? 0) - (a.latest_cents ?? 0));

const sumAccts = (rows: typeof accounts) => rows.reduce((acc, r) => acc + (r.latest_cents ?? 0), 0);
const cashTotal = sumAccts(cash);
const investTotal = sumAccts(invest);
const otherTotal = sumAccts(other);
const liabTotal = sumAccts(liab);
const privateTotal = privateInv.reduce((acc, r) => acc + r.current_value_cents, 0);
const uncalledTotal = privateInv.reduce((acc, r) => acc + r.outstanding_cost_basis_cents, 0);

const lastSyncedAt = accounts.reduce<number | null>(
  (max, a) => (a.latest_as_of && (!max || a.latest_as_of > max) ? a.latest_as_of : max),
  null,
);

const deltas = computeDeltas(series);
const attribution = computeChangeAttribution(series);
const { categories: allocCategories, totalCents: grossAssetsCents } = computeAllocation(accounts, privateInv);
const topPositions = topConcentration(accounts, privateInv, grossAssetsCents);

const deltaRows: Array<{ label: string; d: { cents: number; pct: number } | null }> = [
  { label: '1d',  d: deltas.d1  },
  { label: '1w',  d: deltas.w1  },
  { label: '1m',  d: deltas.m1  },
  { label: 'ytd', d: deltas.ytd },
  { label: '1y',  d: deltas.y1  },
];
const signedUSD = (cents: number) => (cents >= 0 ? '+' : '−') + fmtUSD.format(Math.abs(cents) / 100);
const signedPct = (pct: number) => (pct >= 0 ? '+' : '−') + (Math.abs(pct) * 100).toFixed(1) + '%';

const hasAny = accounts.length > 0 || privateInv.length > 0;
---
<Shell lastSyncedAt={lastSyncedAt}>
  {!hasAny ? (
    <p class="empty">NO ACCOUNTS YET — ASK AN AGENT TO ADD ONE.</p>
  ) : (
    <div class="ledger">
      <aside class="rail">
        <div class="rail-label">net worth</div>
        <div class="rail-value num" title={uncalledTotal > 0 ? `Net of ${fmtUSD.format(uncalledTotal / 100)} in uncalled SBS / fund commitments. Gross is ${fmtUSD.format(nw.total_usd)}.` : undefined}>
          {fmtUSD.format((nw.total_cents - uncalledTotal) / 100)}
        </div>

        <div class="rail-breakdown">
          {/* Liquid here is gross spendable assets (cash + invest + other);
              liabilities live on their own row. NAV math: liquid − uncalled
              + private − liabilities = the displayed net worth. */}
          <div class="bd-row" title="Cash, investments, and other accounts — gross of debt. Liabilities show separately below.">
            <span class="cat">liquid</span>
            <span class="val num">{fmtUSD.format((nw.liquid_cents + liabTotal - uncalledTotal) / 100)}</span>
          </div>
          {uncalledTotal > 0 && (
            <div class="bd-row sub" title={`Committed SBS / fund allocations not yet wired (${fmtUSD.format(uncalledTotal / 100)}). Subtracted from spendable liquid because the cash is earmarked for an unscheduled capital call.`}>
              <span class="cat">uncalled</span>
              <span class="val num">−{fmtUSD.format(uncalledTotal / 100)}</span>
            </div>
          )}
          <div class="bd-row"><span class="cat">private</span><span class="val num">{fmtUSD.format(nw.private_usd)}</span></div>
          {liabTotal > 0 && (
            <div class="bd-row"><span class="cat">liabilities</span><span class="val num">−{fmtUSD.format(liabTotal / 100)}</span></div>
          )}
        </div>

        <div class="rail-label">change</div>
        <div class="rail-breakdown">
          {deltaRows.map((r) => (
            <div class="bd-row">
              <span class="cat">{r.label}</span>
              {r.d == null ? (
                <span class="val num muted">—</span>
              ) : (
                <span class={`val num ${r.d.cents >= 0 ? 'pos' : 'neg'}`}>
                  {signedUSD(r.d.cents)}
                  <span class="dpct">{signedPct(r.d.pct)}</span>
                </span>
              )}
            </div>
          ))}
        </div>

        <div class="rail-meta">
          <div>{accounts.length} accounts · {privateInv.length} private</div>
        </div>
      </aside>

      <div class="ledger-main">
        {syncIssues.length > 0 && (
          <a class="sync-alert" href="/connect">
            <span class="alert-label">sync {syncIssues.length === 1 ? 'issue' : 'issues'}</span>
            <span class="alert-list">
              {syncIssues.map((i, idx) => (
                <span class="alert-item">
                  {idx > 0 && <span class="sep"> · </span>}
                  {i.institution}
                  <span class="alert-why">
                    {' '}({i.last_error ? (i.last_error.length > 40 ? i.last_error.slice(0, 40) + '…' : i.last_error) : 'stale'})
                  </span>
                </span>
              ))}
            </span>
          </a>
        )}

        <NetWorthChart series={series} />

        <div class="summary-grid">
          <ChangeAttribution attribution={attribution} />
          <div class="stack-col">
            {allocCategories.length > 0 && (
              <AllocationMix categories={allocCategories} totalCents={grossAssetsCents} />
            )}
            {topPositions.length > 0 && (
              <Concentration positions={topPositions} />
            )}
          </div>
        </div>

        {cashInsts.length > 0 && (
          <LedgerSection title="Cash & Equivalents" count={pluralize(cash.length, 'account')} subtotal={fmtUSDsigned(cashTotal)}>
            {cashInsts.map((inst) => (
              <LedgerInstitution institution={inst.institution} totalCents={inst.totalCents} kinds={inst.kinds} />
            ))}
          </LedgerSection>
        )}

        {investRows.length > 0 && (
          <LedgerSection title="Investments" count={pluralize(invest.length, 'account')} subtotal={fmtUSDsigned(investTotal)}>
            {investRows.map((a) => (
              <LedgerRow
                name={a.name}
                sub={`${a.institution} · ${prettyKind(a.kind)}${a.note ? ` · ${a.note}` : ''}`}
                owner={a.owner}
                amount={fmtUSD.format((a.latest_cents ?? 0) / 100)}
                href={`/accounts/${a.id}`}
              />
            ))}
          </LedgerSection>
        )}

        {privateInv.length > 0 && (
          <LedgerSection title="Private Investments" count={pluralize(privateInv.length, 'position')} subtotal={fmtUSDsigned(privateTotal)}>
            {privateInv.map((pi) => {
              const baseSub = pi.investment_count > 0
                ? `${prettyKind(pi.kind)} · ${pluralize(pi.investment_count, 'position')}`
                : prettyKind(pi.kind);
              const sub = pi.outstanding_cost_basis_cents > 0
                ? `${baseSub} · ${fmtUSD.format(pi.outstanding_cost_basis_cents / 100)} uncalled`
                : baseSub;
              return (
                <LedgerRow
                  name={pi.name}
                  sub={sub}
                  owner={pi.owner}
                  amount={fmtUSD.format(pi.current_value_cents / 100)}
                  href={`/private-investments/${pi.id}`}
                />
              );
            })}
          </LedgerSection>
        )}

        {otherInsts.length > 0 && (
          <LedgerSection title="Other" count={pluralize(other.length, 'account')} subtotal={fmtUSDsigned(otherTotal)}>
            {otherInsts.map((inst) => (
              <LedgerInstitution institution={inst.institution} totalCents={inst.totalCents} kinds={inst.kinds} />
            ))}
          </LedgerSection>
        )}

        {liabRows.length > 0 && (
          <LedgerSection
            title="Liabilities"
            count={pluralize(liab.length, 'account')}
            subtotal={fmtUSDsigned(-liabTotal)}
            negSubtotal
          >
            {liabRows.map((a) => (
              <LedgerRow
                name={a.name}
                sub={`${a.institution} · ${prettyKind(a.kind)}${a.note ? ` · ${a.note}` : ''}`}
                owner={a.owner}
                amount={fmtUSD.format((a.latest_cents ?? 0) / 100)}
                negAmount
                href={`/accounts/${a.id}`}
              />
            ))}
          </LedgerSection>
        )}
      </div>
    </div>
  )}
</Shell>

<style>
  .ledger {
    display: grid;
    grid-template-columns: 16rem 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .rail {
    position: sticky;
    top: var(--header-offset);
    display: grid;
    gap: var(--space-4);
  }
  .rail-label {
    font-size: var(--size-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
    font-weight: 500;
  }
  .rail-value {
    font-size: var(--size-2xl);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin-top: calc(-1 * var(--space-2));
  }
  .rail-breakdown { display: grid; gap: 0; }
  .bd-row {
    display: grid;
    grid-template-columns: 1fr auto;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
    font-size: var(--size-sm);
  }
  .bd-row:first-child { border-top: 1px solid var(--rule); }
  .bd-row .cat {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
  }
  .bd-row .dpct {
    margin-left: var(--space-1);
    font-size: var(--size-xs);
    color: var(--fg-muted);
  }
  /* Sub-rows: smaller, muted, visually attached to the row above (no top
     gap; suppress that row's bottom border via :has). Both columns inherit
     the muted styling so the label and value read as secondary together. */
  .bd-row.sub {
    font-size: var(--size-xs);
    padding-top: 0;
    border-bottom: 1px solid var(--rule);
  }
  .bd-row.sub .cat,
  .bd-row.sub .val { color: var(--fg-muted); }
  .bd-row:has(+ .sub) { border-bottom: none; padding-bottom: var(--space-1); }
  .rail-meta {
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ledger-main { display: grid; gap: var(--space-4); }

  /* Below the chart: change attribution matrix (left) sits next to the
     stacked allocation + top-positions panels (right). Collapses to a
     single column at narrow widths. */
  .summary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    align-items: start;
  }
  .summary-grid .stack-col { display: grid; gap: var(--space-6); }
  @media (max-width: 64rem) {
    .summary-grid { grid-template-columns: 1fr; }
  }

  .sync-alert {
    display: flex;
    gap: var(--space-3);
    align-items: baseline;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--neg);
    color: var(--neg);
    text-decoration: none;
    font-size: var(--size-sm);
  }
  .sync-alert:hover { background: color-mix(in srgb, var(--neg) 6%, transparent); }
  .sync-alert .alert-label {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
    flex-shrink: 0;
  }
  .sync-alert .alert-list { color: var(--fg); }
  .sync-alert .alert-why { color: var(--fg-muted); }
  .sync-alert .sep { color: var(--fg-muted); }

  @media (max-width: 52rem) {
    .ledger { grid-template-columns: 1fr; gap: var(--space-6); }
    .rail {
      position: static;
      padding-bottom: var(--space-6);
      border-bottom: 1px solid var(--rule);
    }
    .rail-value { font-size: var(--size-2xl); }
  }
</style>
