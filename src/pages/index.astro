---
import { env } from 'cloudflare:workers';
import { db } from '../db';
import { netWorth, listAccounts, listIlliquidAssets } from '../ops/reads';
import { forecastFlows, type ProjectedFlow } from '../ops/flows';
import { fmtUSD, fmtUSDsigned, fmtDate, prettyKind, pluralize } from '../lib/format';
import Shell from '../layouts/Shell.astro';
import LedgerSection from '../components/LedgerSection.astro';
import LedgerRow from '../components/LedgerRow.astro';

const d = db(env.DB);
const FORECAST_DAYS = 30;
const [nw, accounts, illiquid, projected] = await Promise.all([
  netWorth(d),
  listAccounts(d),
  listIlliquidAssets(d),
  forecastFlows(d, FORECAST_DAYS),
]);

const cash   = accounts.filter((a) => !a.is_liability && ['checking', 'savings'].includes(a.kind));
const invest = accounts.filter((a) => !a.is_liability && ['brokerage', 'retirement', 'education', 'crypto'].includes(a.kind));
const other  = accounts.filter((a) => !a.is_liability && !['checking', 'savings', 'brokerage', 'retirement', 'education', 'crypto'].includes(a.kind));
const liab   = accounts.filter((a) => !!a.is_liability);
illiquid.sort((a, b) => b.current_value_cents - a.current_value_cents);

type KindLine = { kind: string; count: number; totalCents: number };
type InstGroup = { institution: string; totalCents: number; kinds: KindLine[] };

function rollupByInstitution(rows: typeof accounts): InstGroup[] {
  const insts = new Map<string, InstGroup>();
  for (const r of rows) {
    let g = insts.get(r.institution);
    if (!g) {
      g = { institution: r.institution, totalCents: 0, kinds: [] };
      insts.set(r.institution, g);
    }
    let k = g.kinds.find((x) => x.kind === r.kind);
    if (!k) {
      k = { kind: r.kind, count: 0, totalCents: 0 };
      g.kinds.push(k);
    }
    k.count += 1;
    k.totalCents += r.latest_cents ?? 0;
    g.totalCents += r.latest_cents ?? 0;
  }
  for (const g of insts.values()) {
    g.kinds.sort((a, b) => Math.abs(b.totalCents) - Math.abs(a.totalCents));
  }
  return [...insts.values()].sort((a, b) => Math.abs(b.totalCents) - Math.abs(a.totalCents));
}

const cashInsts   = rollupByInstitution(cash);
const investInsts = rollupByInstitution(invest);
const otherInsts  = rollupByInstitution(other);
const liabInsts   = rollupByInstitution(liab);

const sumAccts = (rows: typeof accounts) => rows.reduce((acc, r) => acc + (r.latest_cents ?? 0), 0);
const cashTotal = sumAccts(cash);
const investTotal = sumAccts(invest);
const otherTotal = sumAccts(other);
const liabTotal = sumAccts(liab);
const illiquidTotal = illiquid.reduce((acc, r) => acc + r.current_value_cents, 0);

const lastSyncedAt = accounts.reduce<number | null>(
  (max, a) => (a.latest_as_of && (!max || a.latest_as_of > max) ? a.latest_as_of : max),
  null,
);

type FlowSummary = {
  flowId: string;
  direction: 'inflow' | 'outflow';
  cadence: string;
  label: string;
  meta: string;                  // "Biweekly · 2 events" or "Apr 24" for one-offs
  count: number;
  totalCents: number;
  totalLowCents: number | null;
  totalHighCents: number | null;
  amountDisplay: string;         // signed; range if low/high differ
};

function summarize(items: ProjectedFlow[]): FlowSummary[] {
  const byFlow = new Map<string, FlowSummary & { firstDate: number }>();
  for (const p of items) {
    let s = byFlow.get(p.flowId);
    if (!s) {
      s = {
        flowId: p.flowId,
        direction: p.direction,
        cadence: p.cadence,
        label: p.label,
        meta: '',
        count: 0,
        firstDate: p.date,
        totalCents: 0,
        totalLowCents: null,
        totalHighCents: null,
        amountDisplay: '',
      };
      byFlow.set(p.flowId, s);
    }
    s.count += 1;
    s.totalCents += p.amountExpectedCents;
    if (p.amountLowCents != null) s.totalLowCents = (s.totalLowCents ?? 0) + p.amountLowCents;
    if (p.amountHighCents != null) s.totalHighCents = (s.totalHighCents ?? 0) + p.amountHighCents;
    if (p.date < s.firstDate) s.firstDate = p.date;
  }
  return [...byFlow.values()].map((s) => {
    const sign = s.direction === 'outflow' ? -1 : 1;
    const meta = s.cadence === 'once'
      ? fmtDate(s.firstDate)
      : `${prettyKind(s.cadence)} · ${pluralize(s.count, 'event')}`;
    const hasRange =
      s.totalLowCents != null &&
      s.totalHighCents != null &&
      s.totalLowCents !== s.totalHighCents;
    const amountDisplay = hasRange
      ? `${fmtUSD.format((sign * (s.totalLowCents ?? 0)) / 100)} – ${fmtUSD.format((sign * (s.totalHighCents ?? 0)) / 100)}`
      : fmtUSD.format((sign * s.totalCents) / 100);
    return { ...s, meta, amountDisplay };
  });
}

const summaries = summarize(projected).sort((a, b) => b.totalCents - a.totalCents);
const inflowSummaries = summaries.filter((s) => s.direction === 'inflow');
const outflowSummaries = summaries.filter((s) => s.direction === 'outflow');
const inflowEvents = projected.filter((p) => p.direction === 'inflow').length;
const outflowEvents = projected.filter((p) => p.direction === 'outflow').length;
const inflowCents = inflowSummaries.reduce((acc, s) => acc + s.totalCents, 0);
const outflowCents = outflowSummaries.reduce((acc, s) => acc + s.totalCents, 0);
const netFlowCents = inflowCents - outflowCents;

const hasAny = accounts.length > 0 || illiquid.length > 0;
---
<Shell lastSyncedAt={lastSyncedAt}>
  {!hasAny ? (
    <p class="empty">NO ACCOUNTS YET — ASK AN AGENT TO ADD ONE.</p>
  ) : (
    <div class="ledger">
      <aside class="rail">
        <div class="rail-label">net worth</div>
        <div class="rail-value num">{fmtUSD.format(nw.total_usd)}</div>

        <div class="rail-breakdown">
          <div class="bd-row"><span class="cat">liquid</span><span class="val num">{fmtUSD.format(nw.liquid_usd)}</span></div>
          <div class="bd-row"><span class="cat">illiquid</span><span class="val num">{fmtUSD.format(nw.illiquid_usd)}</span></div>
        </div>

        <div class="rail-meta">
          <div>{accounts.length} accounts · {illiquid.length} illiquid</div>
        </div>
      </aside>

      <div class="ledger-main">
        {cashInsts.length > 0 && (
          <LedgerSection title="Cash & Equivalents" count={pluralize(cash.length, 'account')} subtotal={fmtUSDsigned(cashTotal)}>
            {cashInsts.map((inst) => (
              <div class="inst-group">
                <div class="inst-row">
                  <span class="inst-name">{inst.institution}</span>
                  <span class="inst-total num">{fmtUSD.format(inst.totalCents / 100)}</span>
                </div>
                {inst.kinds.map((k) => (
                  <div class="kind-row">
                    <span class="kind-label">{prettyKind(k.kind)} · {pluralize(k.count, 'account')}</span>
                    <span class="kind-total num">{fmtUSD.format(k.totalCents / 100)}</span>
                  </div>
                ))}
              </div>
            ))}
          </LedgerSection>
        )}

        {investInsts.length > 0 && (
          <LedgerSection title="Investments" count={pluralize(invest.length, 'account')} subtotal={fmtUSDsigned(investTotal)}>
            {investInsts.map((inst) => (
              <div class="inst-group">
                <div class="inst-row">
                  <span class="inst-name">{inst.institution}</span>
                  <span class="inst-total num">{fmtUSD.format(inst.totalCents / 100)}</span>
                </div>
                {inst.kinds.map((k) => (
                  <div class="kind-row">
                    <span class="kind-label">{prettyKind(k.kind)} · {pluralize(k.count, 'account')}</span>
                    <span class="kind-total num">{fmtUSD.format(k.totalCents / 100)}</span>
                  </div>
                ))}
              </div>
            ))}
          </LedgerSection>
        )}

        {illiquid.length > 0 && (
          <LedgerSection title="Illiquid" count={pluralize(illiquid.length, 'position')} subtotal={fmtUSDsigned(illiquidTotal)}>
            {illiquid.map((ia) => (
              <LedgerRow
                name={ia.name}
                sub={ia.investment_count > 0
                  ? `${prettyKind(ia.kind)} · ${pluralize(ia.investment_count, 'position')}`
                  : prettyKind(ia.kind)}
                owner={ia.owner}
                amount={fmtUSD.format(ia.current_value_cents / 100)}
              />
            ))}
          </LedgerSection>
        )}

        {otherInsts.length > 0 && (
          <LedgerSection title="Other" count={pluralize(other.length, 'account')} subtotal={fmtUSDsigned(otherTotal)}>
            {otherInsts.map((inst) => (
              <div class="inst-group">
                <div class="inst-row">
                  <span class="inst-name">{inst.institution}</span>
                  <span class="inst-total num">{fmtUSD.format(inst.totalCents / 100)}</span>
                </div>
                {inst.kinds.map((k) => (
                  <div class="kind-row">
                    <span class="kind-label">{prettyKind(k.kind)} · {pluralize(k.count, 'account')}</span>
                    <span class="kind-total num">{fmtUSD.format(k.totalCents / 100)}</span>
                  </div>
                ))}
              </div>
            ))}
          </LedgerSection>
        )}

        {summaries.length > 0 && (
          <div class="upcoming">
            <div class="upcoming-cols">
              {inflowSummaries.length > 0 && (
                <LedgerSection
                  title={`Receiving · ${FORECAST_DAYS}d`}
                  count={pluralize(inflowEvents, 'event')}
                  subtotal={fmtUSDsigned(inflowCents)}
                >
                  {inflowSummaries.map((s) => (
                    <div class="flow-row">
                      <div class="flow-primary">
                        <span class="flow-label">{s.label}</span>
                        <span class="flow-meta">{s.meta}</span>
                      </div>
                      <span class="flow-amt num">{s.amountDisplay}</span>
                    </div>
                  ))}
                </LedgerSection>
              )}
              {outflowSummaries.length > 0 && (
                <LedgerSection
                  title={`Paying · ${FORECAST_DAYS}d`}
                  count={pluralize(outflowEvents, 'event')}
                  subtotal={fmtUSDsigned(-outflowCents)}
                  negSubtotal
                >
                  {outflowSummaries.map((s) => (
                    <div class="flow-row">
                      <div class="flow-primary">
                        <span class="flow-label">{s.label}</span>
                        <span class="flow-meta">{s.meta}</span>
                      </div>
                      <span class="flow-amt num neg">{s.amountDisplay}</span>
                    </div>
                  ))}
                </LedgerSection>
              )}
            </div>
            <div class="upcoming-net">
              <span class="net-label">Net · Next {FORECAST_DAYS} Days</span>
              <span class:list={['net-amt', 'num', { neg: netFlowCents < 0 }]}>
                {fmtUSDsigned(netFlowCents)}
              </span>
            </div>
          </div>
        )}

        {liabInsts.length > 0 && (
          <LedgerSection
            title="Liabilities"
            count={pluralize(liab.length, 'account')}
            subtotal={fmtUSDsigned(-liabTotal)}
            negSubtotal
          >
            {liabInsts.map((inst) => (
              <div class="inst-group">
                <div class="inst-row">
                  <span class="inst-name">{inst.institution}</span>
                  <span class="inst-total num neg">{fmtUSD.format(-inst.totalCents / 100)}</span>
                </div>
                {inst.kinds.map((k) => (
                  <div class="kind-row">
                    <span class="kind-label">{prettyKind(k.kind)} · {pluralize(k.count, 'account')}</span>
                    <span class="kind-total num neg">{fmtUSD.format(-k.totalCents / 100)}</span>
                  </div>
                ))}
              </div>
            ))}
          </LedgerSection>
        )}
      </div>
    </div>
  )}
</Shell>

<style>
  .ledger {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .rail {
    position: sticky;
    top: var(--space-4);
    display: grid;
    gap: var(--space-4);
  }
  .rail-label {
    font-size: var(--size-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
    font-weight: 500;
  }
  .rail-value {
    font-size: var(--size-2xl);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin-top: calc(-1 * var(--space-2));
  }
  .rail-breakdown { display: grid; gap: 0; }
  .bd-row {
    display: grid;
    grid-template-columns: 1fr auto;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
    font-size: var(--size-sm);
  }
  .bd-row:first-child { border-top: 1px solid var(--rule); }
  .bd-row .cat {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
  }
  .rail-meta {
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ledger-main { display: grid; gap: var(--space-4); }

  .inst-group {
    border-bottom: 1px solid var(--rule);
  }
  .inst-group:last-child { border-bottom: none; }
  .inst-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    align-items: baseline;
    font-size: var(--size-sm);
    font-weight: 500;
  }
  .inst-total { font-variant-numeric: tabular-nums; text-align: right; }
  .kind-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-3);
    padding: var(--space-1) var(--space-3) var(--space-1) calc(var(--space-3) + var(--space-4));
    align-items: baseline;
  }
  .kind-label {
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .kind-total {
    font-size: var(--size-xs);
    color: var(--fg-muted);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .inst-group .kind-row:last-child { padding-bottom: var(--space-2); }

  .upcoming { display: grid; gap: var(--space-2); }
  .upcoming-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
    align-items: start;
  }
  .upcoming-net {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--rule);
    background: var(--bg-subtle);
  }
  .net-label {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-muted);
  }
  .net-amt {
    font-size: var(--size-sm);
    font-variant-numeric: tabular-nums;
    font-weight: 500;
  }
  .net-amt.neg { color: var(--fg); }

  .flow-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
  }
  .flow-row:last-child { border-bottom: none; }
  .flow-primary { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .flow-label { font-size: var(--size-sm); }
  .flow-meta {
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .flow-amt {
    font-size: var(--size-sm);
    font-variant-numeric: tabular-nums;
    text-align: right;
    white-space: nowrap;
  }

  @media (max-width: 52rem) {
    .upcoming-cols { grid-template-columns: 1fr; }
  }

  @media (max-width: 52rem) {
    .ledger { grid-template-columns: 1fr; gap: var(--space-6); }
    .rail {
      position: static;
      padding-bottom: var(--space-6);
      border-bottom: 1px solid var(--rule);
    }
    .rail-value { font-size: var(--size-2xl); }
  }
</style>
