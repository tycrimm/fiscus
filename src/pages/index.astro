---
import { env } from 'cloudflare:workers';
import { db } from '../db';
import { netWorth, listAccounts, listIlliquidAssets } from '../ops/reads';
import { fmtUSD, fmtUSDsigned, fmtDate, money, prettyKind, pluralize } from '../lib/format';
import Shell from '../layouts/Shell.astro';
import LedgerSection from '../components/LedgerSection.astro';
import LedgerRow from '../components/LedgerRow.astro';

const d = db(env.DB);
const [nw, accounts, illiquid] = await Promise.all([
  netWorth(d),
  listAccounts(d),
  listIlliquidAssets(d),
]);

const cash   = accounts.filter((a) => !a.is_liability && ['checking', 'savings'].includes(a.kind));
const invest = accounts.filter((a) => !a.is_liability && ['brokerage', 'retirement', 'crypto'].includes(a.kind));
const other  = accounts.filter((a) => !a.is_liability && !['checking', 'savings', 'brokerage', 'retirement', 'crypto'].includes(a.kind));
const liab   = accounts.filter((a) => !!a.is_liability);
illiquid.sort((a, b) => b.current_value_cents - a.current_value_cents);

type Group = {
  key: string;
  institution: string;
  kind: string;
  totalCents: number;
  count: number;
  latestAsOf: number | null;
};

function rollup(rows: typeof accounts): Group[] {
  const groups = new Map<string, Group>();
  for (const r of rows) {
    const key = `${r.institution}|${r.kind}`;
    let g = groups.get(key);
    if (!g) {
      g = { key, institution: r.institution, kind: r.kind, totalCents: 0, count: 0, latestAsOf: null };
      groups.set(key, g);
    }
    g.totalCents += r.latest_cents ?? 0;
    g.count += 1;
    if (r.latest_as_of && (!g.latestAsOf || r.latest_as_of > g.latestAsOf)) {
      g.latestAsOf = r.latest_as_of;
    }
  }
  return [...groups.values()].sort((a, b) => Math.abs(b.totalCents) - Math.abs(a.totalCents));
}

const cashGroups   = rollup(cash);
const investGroups = rollup(invest);
const otherGroups  = rollup(other);
const liabGroups   = rollup(liab);

const sumAccts = (rows: typeof accounts) => rows.reduce((acc, r) => acc + (r.latest_cents ?? 0), 0);
const cashTotal = sumAccts(cash);
const investTotal = sumAccts(invest);
const otherTotal = sumAccts(other);
const liabTotal = sumAccts(liab);
const illiquidTotal = illiquid.reduce((acc, r) => acc + r.current_value_cents, 0);

const hasAny = accounts.length > 0 || illiquid.length > 0;
---
<Shell>
  {!hasAny ? (
    <p class="empty">NO ACCOUNTS YET — ASK AN AGENT TO ADD ONE.</p>
  ) : (
    <div class="ledger">
      <aside class="rail">
        <div class="rail-label">net worth</div>
        <div class="rail-value num">{fmtUSD.format(nw.total_usd)}</div>

        <div class="rail-breakdown">
          <div class="bd-row"><span class="cat">liquid</span><span class="val num">{fmtUSD.format(nw.liquid_usd)}</span></div>
          <div class="bd-row"><span class="cat">illiquid</span><span class="val num">{fmtUSD.format(nw.illiquid_usd)}</span></div>
        </div>

        <div class="rail-meta">
          <div>{accounts.length} accounts · {illiquid.length} illiquid</div>
        </div>
      </aside>

      <div class="ledger-main">
        {cashGroups.length > 0 && (
          <LedgerSection title="Cash & Equivalents" count={pluralize(cash.length, 'account')} subtotal={fmtUSDsigned(cashTotal)}>
            {cashGroups.map((g) => (
              <LedgerRow
                name={g.institution}
                sub={`${prettyKind(g.kind)} · ${pluralize(g.count, 'account')}`}
                amount={fmtUSD.format(g.totalCents / 100)}
                asOf={fmtDate(g.latestAsOf)}
              />
            ))}
          </LedgerSection>
        )}

        {investGroups.length > 0 && (
          <LedgerSection title="Investments" count={pluralize(invest.length, 'account')} subtotal={fmtUSDsigned(investTotal)}>
            {investGroups.map((g) => (
              <LedgerRow
                name={g.institution}
                sub={`${prettyKind(g.kind)} · ${pluralize(g.count, 'account')}`}
                amount={fmtUSD.format(g.totalCents / 100)}
                asOf={fmtDate(g.latestAsOf)}
              />
            ))}
          </LedgerSection>
        )}

        {illiquid.length > 0 && (
          <LedgerSection title="Illiquid" count={pluralize(illiquid.length, 'position')} subtotal={fmtUSDsigned(illiquidTotal)}>
            {illiquid.map((ia) => (
              <LedgerRow
                name={ia.name}
                sub={ia.investment_count > 0
                  ? `${prettyKind(ia.kind)} · ${pluralize(ia.investment_count, 'position')}`
                  : prettyKind(ia.kind)}
                owner={ia.owner}
                amount={fmtUSD.format(ia.current_value_cents / 100)}
                asOf="—"
              />
            ))}
          </LedgerSection>
        )}

        {otherGroups.length > 0 && (
          <LedgerSection title="Other" count={pluralize(other.length, 'account')} subtotal={fmtUSDsigned(otherTotal)}>
            {otherGroups.map((g) => (
              <LedgerRow
                name={g.institution}
                sub={`${prettyKind(g.kind)} · ${pluralize(g.count, 'account')}`}
                amount={fmtUSD.format(g.totalCents / 100)}
                asOf={fmtDate(g.latestAsOf)}
              />
            ))}
          </LedgerSection>
        )}

        {liabGroups.length > 0 && (
          <LedgerSection
            title="Liabilities"
            count={pluralize(liab.length, 'account')}
            subtotal={fmtUSDsigned(-liabTotal)}
            negSubtotal
          >
            {liabGroups.map((g) => (
              <LedgerRow
                name={g.institution}
                sub={`${prettyKind(g.kind)} · ${pluralize(g.count, 'account')}`}
                amount={fmtUSD.format(-g.totalCents / 100)}
                asOf={fmtDate(g.latestAsOf)}
                negAmount
              />
            ))}
          </LedgerSection>
        )}
      </div>
    </div>
  )}
</Shell>

<style>
  .ledger {
    display: grid;
    grid-template-columns: 16rem 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .rail {
    position: sticky;
    top: var(--space-4);
    display: grid;
    gap: var(--space-6);
  }
  .rail-label {
    font-size: var(--size-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
    font-weight: 500;
  }
  .rail-value {
    font-size: var(--size-3xl);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin-top: calc(-1 * var(--space-4));
  }
  .rail-breakdown { display: grid; gap: 0; }
  .bd-row {
    display: grid;
    grid-template-columns: 1fr auto;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
    font-size: var(--size-sm);
  }
  .bd-row:first-child { border-top: 1px solid var(--rule); }
  .bd-row .cat {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
  }
  .rail-meta {
    font-size: var(--size-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ledger-main { display: grid; gap: var(--space-6); }

  @media (max-width: 52rem) {
    .ledger { grid-template-columns: 1fr; gap: var(--space-6); }
    .rail {
      position: static;
      padding-bottom: var(--space-6);
      border-bottom: 1px solid var(--rule);
    }
    .rail-value { font-size: var(--size-2xl); }
  }
</style>
