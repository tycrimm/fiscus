---
import { env } from 'cloudflare:workers';
import { drizzle } from 'drizzle-orm/d1';
import { listPlaidItems } from '../ops/plaid';
import { fmtDateTime } from '../lib/format';
import * as schema from '../db/schema';
import Shell from '../layouts/Shell.astro';

const d = drizzle(env.DB, { schema });
const items = await listPlaidItems(d);
---
<Shell title="connect">
  <h1>connections</h1>

  {items.length === 0 ? (
    <p class="empty">NO BANKS CONNECTED YET.</p>
  ) : (
    <table>
      <thead>
        <tr>
          <th>institution</th>
          <th>owner</th>
          <th>status</th>
          <th class="num-col">last sync</th>
        </tr>
      </thead>
      <tbody>
        {items.map((it) => (
          <tr>
            <td>{it.institutionName}</td>
            <td><span class="owner-tag">{it.owner}</span></td>
            <td><span class:list={['status-badge', it.status === 'active' ? 'pos' : 'neg']}>{it.status}</span>{it.lastError ? <span class="muted"> · {it.lastError}</span> : null}</td>
            <td class="num-col muted">{fmtDateTime(it.lastSyncAt)} <span class="tz">PT</span></td>
          </tr>
        ))}
      </tbody>
    </table>
  )}

  <div class="connect-flow" data-stage="idle" id="flow">
    <button id="connect-btn" type="button">+ connect bank</button>

    <div class="picker" id="picker">
      <span class="picker-label">connect for</span>
      <button class="own-btn" type="button" data-owner="tyler">tyler</button>
      <button class="own-btn" type="button" data-owner="julianne">julianne</button>
      <button class="own-btn" type="button" data-owner="joint">joint</button>
      <button id="cancel-btn" type="button" class="btn-ghost">cancel</button>
    </div>

    <span id="status" class="muted"></span>
  </div>

  <style>
    .status-badge {
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: var(--size-xs);
      font-weight: 500;
    }
    .owner-tag {
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: var(--size-xs);
      color: var(--fg-muted);
    }
    .tz {
      font-size: var(--size-xs);
      color: var(--fg-muted);
      letter-spacing: 0.08em;
      margin-left: var(--space-1);
    }

    .connect-flow {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      flex-wrap: wrap;
      margin-top: var(--space-8);
    }

    /* idle: button visible, picker hidden. picking: inverted. busy: both hidden, status visible. */
    .connect-flow[data-stage="idle"]    .picker { display: none; }
    .connect-flow[data-stage="picking"] #connect-btn { display: none; }
    .connect-flow[data-stage="busy"]    #connect-btn { display: none; }
    .connect-flow[data-stage="busy"]    .picker { display: none; }

    .picker {
      display: inline-flex;
      align-items: center;
      gap: 0;
      border: 1px solid var(--fg);
    }
    .picker-label {
      padding: var(--space-3) var(--space-4);
      font-size: var(--size-xs);
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--fg-muted);
      border-right: 1px solid var(--fg);
      background: var(--bg-subtle);
    }
    .picker .own-btn {
      border: 0;
      border-right: 1px solid var(--fg);
      background: var(--bg);
      color: var(--fg);
      font-size: var(--size-xs);
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: var(--space-3) var(--space-4);
      cursor: pointer;
    }
    .picker .own-btn:hover { background: var(--fg); color: var(--bg); }
    .picker #cancel-btn {
      border: 0;
      border-left: 0;
      background: var(--bg);
      color: var(--fg-muted);
      font-size: var(--size-xs);
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: var(--space-3) var(--space-4);
      cursor: pointer;
    }
    .picker #cancel-btn:hover { color: var(--fg); }

    #status {
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-size: var(--size-xs);
    }
  </style>

  <script src="https://cdn.plaid.com/link/v2/stable/link-initialize.js" is:inline></script>
  <script is:inline>
    (() => {
      const flow = document.getElementById('flow');
      const connectBtn = document.getElementById('connect-btn');
      const cancelBtn = document.getElementById('cancel-btn');
      const status = document.getElementById('status');
      const ownerBtns = document.querySelectorAll('.own-btn');

      const setStage = (s) => flow.setAttribute('data-stage', s);
      const setStatus = (s) => { status.textContent = s; };
      const reset = () => { setStage('idle'); setStatus(''); };

      connectBtn.addEventListener('click', () => {
        setStatus('');
        setStage('picking');
      });

      cancelBtn.addEventListener('click', reset);

      ownerBtns.forEach((b) => {
        b.addEventListener('click', () => kickOff(b.getAttribute('data-owner')));
      });

      async function kickOff(owner) {
        try {
          setStage('busy');
          setStatus('requesting link token…');
          const r = await fetch('/api/plaid/link-token', { method: 'POST' });
          if (!r.ok) throw new Error(await r.text());
          const { link_token } = await r.json();

          setStatus('opening plaid…');
          const handler = window.Plaid.create({
            token: link_token,
            onSuccess: async (public_token, metadata) => {
              setStatus('exchanging token + first sync…');
              const ex = await fetch('/api/plaid/exchange', {
                method: 'POST',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({ public_token, institution: metadata.institution, owner }),
              });
              if (!ex.ok) {
                setStatus('exchange failed: ' + (await ex.text()));
                setStage('idle');
                return;
              }
              setStatus('connected — reloading…');
              setTimeout(() => location.reload(), 600);
            },
            onExit: (err) => {
              if (err) setStatus('plaid exit: ' + err.error_message);
              setStage('idle');
            },
          });
          handler.open();
        } catch (e) {
          setStatus('error: ' + (e?.message ?? e));
          setStage('idle');
        }
      }
    })();
  </script>
</Shell>
