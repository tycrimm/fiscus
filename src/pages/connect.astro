---
import { env } from 'cloudflare:workers';
import { drizzle } from 'drizzle-orm/d1';
import { listPlaidItems } from '../ops/plaid';
import * as schema from '../db/schema';
import Shell from '../layouts/Shell.astro';

const d = drizzle(env.DB, { schema });
const items = await listPlaidItems(d);

const fmtDate = (sec: number | null) =>
  sec ? new Date(sec * 1000).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) : '—';
---
<Shell title="connect">
  <h1>connections</h1>

  {items.length === 0 ? (
    <p class="empty">NO BANKS CONNECTED YET.</p>
  ) : (
    <table>
      <thead>
        <tr>
          <th>institution</th>
          <th>owner</th>
          <th>status</th>
          <th class="num-col">last sync</th>
        </tr>
      </thead>
      <tbody>
        {items.map((it) => (
          <tr>
            <td>{it.institutionName}</td>
            <td><span class="owner-tag">{it.owner}</span></td>
            <td><span class:list={['status-badge', it.status === 'active' ? 'pos' : 'neg']}>{it.status}</span>{it.lastError ? <span class="muted"> · {it.lastError}</span> : null}</td>
            <td class="num-col muted">{fmtDate(it.lastSyncAt)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  )}

  <div class="actions" style="margin-top: var(--space-8)">
    <fieldset class="owner-picker">
      <legend>owner</legend>
      <label><input type="radio" name="owner" value="tyler" checked /> tyler</label>
      <label><input type="radio" name="owner" value="julianne" /> julianne</label>
      <label><input type="radio" name="owner" value="joint" /> joint</label>
    </fieldset>
    <button id="connect-btn" type="button">+ connect bank</button>
    <button id="sync-btn" type="button" class="btn-ghost">sync all</button>
    <span id="status" class="muted" style="font-size: var(--size-sm)"></span>
  </div>

  <style>
    .status-badge {
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: var(--size-xs);
      font-weight: 500;
    }
    .owner-tag {
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: var(--size-xs);
      color: var(--fg-muted);
    }
    #status { text-transform: uppercase; letter-spacing: 0.06em; font-size: var(--size-xs); }
    .actions { display: flex; align-items: center; gap: var(--space-4); flex-wrap: wrap; }
    .owner-picker {
      border: 1px solid var(--rule);
      padding: var(--space-2) var(--space-3);
      display: flex;
      gap: var(--space-3);
      align-items: center;
    }
    .owner-picker legend {
      padding: 0 var(--space-2);
      font-size: var(--size-xs);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--fg-muted);
    }
    .owner-picker label {
      font-size: var(--size-sm);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: var(--space-1);
    }
  </style>

  <script src="https://cdn.plaid.com/link/v2/stable/link-initialize.js" is:inline></script>
  <script is:inline>
    (() => {
      const btn = document.getElementById('connect-btn');
      const syncBtn = document.getElementById('sync-btn');
      const status = document.getElementById('status');
      const setStatus = (s) => { if (status) status.textContent = s; };

      btn?.addEventListener('click', async () => {
        try {
          setStatus('requesting link token…');
          const r = await fetch('/api/plaid/link-token', { method: 'POST' });
          if (!r.ok) throw new Error(await r.text());
          const { link_token } = await r.json();
          setStatus('opening plaid…');
          const handler = window.Plaid.create({
            token: link_token,
            onSuccess: async (public_token, metadata) => {
              setStatus('exchanging token + first sync…');
              const ownerInput = document.querySelector('input[name="owner"]:checked');
              const owner = ownerInput ? ownerInput.value : 'joint';
              const ex = await fetch('/api/plaid/exchange', {
                method: 'POST',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({ public_token, institution: metadata.institution, owner }),
              });
              if (!ex.ok) { setStatus('exchange failed: ' + (await ex.text())); return; }
              setStatus('connected — reloading…');
              setTimeout(() => location.reload(), 600);
            },
            onExit: (err) => { if (err) setStatus('plaid exit: ' + err.error_message); },
          });
          handler.open();
        } catch (e) {
          setStatus('error: ' + (e?.message ?? e));
        }
      });

      syncBtn?.addEventListener('click', async () => {
        setStatus('syncing all items…');
        const r = await fetch('/api/plaid/sync', { method: 'POST' });
        const data = await r.json();
        const failed = data.results.filter((x) => !x.ok).length;
        setStatus(failed === 0 ? `synced ${data.results.length} items.` : `synced with ${failed} failures.`);
        setTimeout(() => location.reload(), 1200);
      });
    })();
  </script>
</Shell>
