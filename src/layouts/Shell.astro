---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'fiscus' } = Astro.props;
const path = Astro.url.pathname;
const active = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title === 'fiscus' ? 'FISCUS' : `${title.toUpperCase()} · FISCUS`}</title>
  </head>
  <body>
    <header class="app-header">
      <a href="/" class="brand">fiscus</a>
      <nav>
        <a href="/" aria-current={active('/') ? 'page' : undefined}>net worth</a>
        <a href="/connect" aria-current={active('/connect') ? 'page' : undefined}>connect</a>
        <a href="/debug" aria-current={active('/debug') ? 'page' : undefined}>debug</a>
      </nav>
    </header>
    <slot />
  </body>
</html>
