---
import '../styles/global.css';
import { fmtDateTime, fmtRelative } from '../lib/format';

interface Props {
  title?: string;
  lastSyncedAt?: number | null;
}
const { title = 'fiscus', lastSyncedAt } = Astro.props;
const path = Astro.url.pathname;
const active = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
const accessEmail = Astro.request.headers.get('cf-access-authenticated-user-email')?.toLowerCase() ?? '';
const showDebug = accessEmail === 'tyler.crimm@gmail.com';

// Cron fires daily at 10:00 UTC (see wrangler.jsonc triggers.crons).
function nextSyncSec(): number {
  const now = new Date();
  const next = new Date(now);
  next.setUTCHours(10, 0, 0, 0);
  if (next <= now) next.setUTCDate(next.getUTCDate() + 1);
  return Math.floor(next.getTime() / 1000);
}
const syncTitle = lastSyncedAt != null
  ? `Last: ${fmtDateTime(lastSyncedAt)} PT · Next: ${fmtDateTime(nextSyncSec())} PT`
  : '';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title === 'fiscus' ? 'FISCUS' : `${title.toUpperCase()} · FISCUS`}</title>
  </head>
  <body>
    <header class="app-header">
      <a href="/" class="brand">fiscus</a>
      <nav>
        <a href="/activity" aria-current={active('/activity') ? 'page' : undefined}>activity</a>
        <a href="/concentration" aria-current={active('/concentration') ? 'page' : undefined}>concentration</a>
        <a href="/flows" aria-current={active('/flows') ? 'page' : undefined}>flows</a>
        <a href="/connect" aria-current={active('/connect') ? 'page' : undefined}>connect</a>
        {showDebug && (
          <a href="/debug" aria-current={active('/debug') ? 'page' : undefined}>debug</a>
        )}
      </nav>
      {lastSyncedAt != null && (
        showDebug ? (
          <a href="/debug" class="synced" title={syncTitle}>
            <svg class="sync-icon" viewBox="0 0 10 10" aria-hidden="true">
              <circle cx="5" cy="5" r="4" fill="none" stroke="currentColor" stroke-width="1" />
              <path d="M5 2.5 L5 5 L7 6" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {fmtRelative(lastSyncedAt)}
          </a>
        ) : (
          <span class="synced" title={syncTitle}>
            <svg class="sync-icon" viewBox="0 0 10 10" aria-hidden="true">
              <circle cx="5" cy="5" r="4" fill="none" stroke="currentColor" stroke-width="1" />
              <path d="M5 2.5 L5 5 L7 6" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {fmtRelative(lastSyncedAt)}
          </span>
        )
      )}
    </header>
    <slot />
    <style>
      .app-header .synced {
        margin-left: auto;
        display: inline-flex;
        align-items: center;
        gap: var(--space-1);
        font-size: var(--size-xs);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--fg-muted);
        text-decoration: none;
      }
      .app-header a.synced:hover { color: var(--fg); }
      .app-header .sync-icon {
        width: 0.75rem;
        height: 0.75rem;
        flex-shrink: 0;
      }

      /* Mobile: brand + sync stay side-by-side on the top line; nav drops
         to its own line beneath them so we don't have to choose between
         overflow and a hamburger. flex-wrap + flex-basis:100% on the nav
         is enough to force the second-row break. */
      @media (max-width: 40rem) {
        .app-header {
          flex-wrap: wrap;
          column-gap: var(--space-4);
          row-gap: var(--space-2);
        }
        .app-header nav {
          order: 3;
          flex-basis: 100%;
          gap: var(--space-4);
          flex-wrap: wrap;
        }
      }
    </style>
  </body>
</html>
